            "data": {
                "success": true,
                "encrypt": false,
                "sql": "SELECT \n        ROW_NUMBER() OVER(ORDER BY NE.NECATSEQ) ORDER_NUM\n        , TOFF.OFFICE_ABBR_NM OFFICESCODE \n        , TOFF.OFFICE_ID OFFICENAMESCODE \n        , CLSCODE.NEMAINCLSCODE \n        , CLSCODE.MAINDESCRIPTION \n        , CLSCODE.NESUBCLSCODE \n        , CLSCODE.SUBDESCRIPTION \n        , USG.DESCRIPTION DESCRIPTION \n        , NEC.MODELNAME \n        , NE.NEALIAS2 \n        , NE.NESCODE \n        , NE.NEALIAS \n        , TOFF.OFFICE_NM OFFICENAME \n        , ADDR.addr1||' '||ADDR.addr2||' '||ADDR.addr3||' '||\n        CASE \n            WHEN BLDG.addrnum     <>     '0' THEN BLDG.addrnum||'번지'\n            ELSE ''\n            END ||\n        CASE \n            WHEN BLDG.addrsubnum    <>    '0' THEN BLDG.addrsubnum||'호' \n            ELSE ''\n        END AS FULL_ADDRESS \n        , BLDG.BLDGSCODE \n        , BLDG.BLDGNAME \n        , 'Y' HAS_LINK \n        , NESU.NEA_NES_CNT \n, NESU.NEA_LINE_CNT \n, NESU.NEA_SVC_CNT \n, NESU.NEA_RELATION_NES_CNT \n, NESU.NEA_RELATION_LINE_CNT \n, NESU.NEA_RELATION_SVC_CNT \n    FROM ndhub.TB_NE NE\n    INNER JOIN ndhub.TB_NECAT NEC ON NEC.NECATSEQ = NE.NECATSEQ\n    INNER JOIN ndhub.TB_NECLSCODE CLSCODE ON NE.MAINCLSCODE = CLSCODE.NEMAINCLSCODE AND NE.SUBCLSCODE = CLSCODE.NESUBCLSCODE\n    INNER JOIN ndhub.TB_NEUSGCODE USG ON USG.svcnetcode = NE.svcnetcode and USG.neusgcode = ne.neusgcode\n\tINNER JOIN ndhub.TB_OFFICE_MST TOFF ON TOFF.office_id = NE.officescode\n    INNER JOIN ndhub.tb_office_org_mapp_mst TOOMM on ne.svcnetcode= TOOMM.svc_net_cd and TOFF.office_id = toomm.office_id \n    INNER JOIN ndhub.VW_ORG_MST VOM5 on TOOMM.ORG_ID = VOM5.ORG_ID \n\tINNER JOIN ndhub.VW_ORG_MST VOM4 on VOM4.ORG_ID = VOM5.HIGHER_ORG_ID \n\tINNER JOIN ndhub.VW_ORG_MST VOM3 on VOM3.ORG_ID = VOM4.HIGHER_ORG_ID\n\tLEFT OUTER JOIN ndhub.TB_ADDR ADDR on ADDR.addrseq = NE.addrseq \n    LEFT OUTER JOIN ndhub.TB_BLDG BLDG ON BLDG.BLDGSCODE = NE.BLDGSCODE\n    LEFT OUTER JOIN ndhub.TB_NEA_NESUIDATA NESU on NESU.NESCODE = NE.NESCODE \n    WHERE 1=1\n            AND NE.NEALIAS LIKE '%' || '부여' || '%'\n        ORDER BY NE.NECATSEQ\n         LIMIT 20 OFFSET 0",
                "total": 619,
