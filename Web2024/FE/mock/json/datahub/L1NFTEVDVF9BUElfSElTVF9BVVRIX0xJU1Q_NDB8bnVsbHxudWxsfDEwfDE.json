  "sql": "SELECT \n    TAARH.API_ID\n    ,TAARH.HIST_SERIAL \n    ,TAM.API_NAME\n    ,TAM.API_URL\n    ,TAM.REQ_PARAM\n    ,TAARH.REG_USER \n    ,TAARH.REFUSE_MSG\n    ,TO_CHAR(TAARH.EXPIRD_DATE , 'YYYY-MM-DD HH24:MI:SS') AS EXPIRD_DATE\n    ,TAARH.API_DESC \n    ,TO_CHAR(TAARH.CREATE_TIME , 'YYYY-MM-DD HH24:MI:SS') AS CREATE_TIME\n    ,TO_CHAR(TAARH.UPDATE_TIME , 'YYYY-MM-DD HH24:MI:SS') AS UPDATE_TIME\n    ,TISM.SYSTEM_DESC \n    ,TAARH.SYSTEM_ID\n    ,TISM.API_KEY\n    ,COALESCE(TAM.KONG_HOST, 'HOST_'|| TAM.API_ID) as KONG_HOST\n    ,TISM.API_KEY AS KONG_KEY\n    , CASE WHEN TAARH.STATUS_CD = 'APPLY' THEN '신청'\n        WHEN TAARH.STATUS_CD = 'GRANT' THEN '승인'\n        WHEN TAARH.STATUS_CD = 'REJECT' THEN '반려'\n        ELSE '회수' \n        END AS STATUS_CD\n        ,CASE \n        WHEN TAM.EXEC_MODE_CD = 'B' THEN 'Batch'\n        WHEN TAM.EXEC_MODE_CD = 'F' THEN 'SFTP'\n        ELSE 'OnDemand'\n        END AS EXEC_MODE_CD\n        ,ROW_NUMBER() OVER (ORDER BY TO_CHAR(TAARH.CREATE_TIME , 'YYYY-MM-DD HH24:MI:SS') DESC) as RANK\n        ,TISM.SYSTEM_NM\n    FROM DATAHUB.TB_API_AUTH_REQ_HIST TAARH\n    LEFT JOIN DATAHUB.TB_API_MST TAM ON TAARH.API_ID = TAM.API_ID\n    LEFT JOIN DATAHUB.TB_INTRL_SYSTEM_MST TISM ON TAARH.SYSTEM_ID = TISM.SYSTEM_ID\n    WHERE TAM.EXEC_MODE_CD != 'F'\n        AND TAARH.API_ID = 40\n            LIMIT 10 OFFSET 0",
