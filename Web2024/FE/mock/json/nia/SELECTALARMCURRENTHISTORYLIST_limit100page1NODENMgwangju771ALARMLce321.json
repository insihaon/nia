        "sql": [
            "SELECT  TC.TICKET_ID\n                , TC.PARENT_TICKET_ID \n                , TC.FAULT_TIME\n                , CASE WHEN TC.STATUS = 'AUTO_FIN' \n                    THEN TC.TICKET_UPDATE_TIME \n                    ELSE SOP.HANDLING_FIN_TIME \n                END AS HANDLING_FIN_TIME\n                , TC.TICKET_TYPE\n                , TC.TICKET_RCA_RESULT_DTL_CODE\n                , TC.STATUS \n                , TA.ROOT_CAUSE_SYSNAMEA\n                , TA.ROOT_CAUSE_PORTA\n                , TA.ROOT_CAUSE_SYSNAMEZ\n                , TA.ROOT_CAUSE_PORTZ\n        FROM    rca.tb_rca_ticket_current TC\n        INNER JOIN rca.tb_rca_ticket_al_current TA ON TC.TICKET_ID = TA.TICKET_ID\n        LEFT JOIN NIA.TB_SOP SOP ON TC.TICKET_ID = SOP.TICKET_ID\n         WHERE (  (\n                        TA.ROOT_CAUSE_SYSNAMEA LIKE '%' || 'gwangju-7712' || '%'\n                        OR \n                        TA.ROOT_CAUSE_SYSNAMEZ LIKE '%' || 'gwangju-7712' || '%'\n                    )\n                    AND (\n                        TA.ROOT_CAUSE_PORTA LIKE '%' || 'ce32/1' || '%'\n                    )\n                    AND TC.FAULT_TIME  >  RCA.FC_GET_MINUS_DAY(7) ) \n        ORDER BY TC.TICKET_ID DESC\n            LIMIT 100 OFFSET 0"
        ],
