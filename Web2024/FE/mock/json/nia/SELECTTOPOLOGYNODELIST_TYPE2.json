    "sql": [
      "SELECT\r\n            row_number() over () AS index\r\n            , node.id\r\n            , node.device_name\r\n            , node.ip_addr\r\n            , node.device_type\r\n            , node.visible\r\n            , coalesce(cast (node.fx as integer), 20 + (node.index * 80)) as fx\r\n            , coalesce(cast (node.fx as integer), 20 + (node.index * 80)) as x\r\n            , coalesce(cast (node.fy as integer), 100) as fy\r\n            , coalesce(cast (node.fy as integer), 100) as y\r\n        from (\r\n            SELECT DISTINCT ON (nm.node_id, nm.node_nm, nm.ip_addr)\r\n                 row_number() over () AS index\r\n                , nm.node_num\r\n                , nm.node_id AS id\r\n                 , nm.node_nm AS device_name\r\n                 , nm.ip_addr AS ip_addr\r\n                 , '4' as device_type\r\n                 , case when nm.admin_yn = 'W' then true\r\n                        else false end as visible\r\n                 , np.fx as fx  \r\n                 , np.fy  as fy\r\n            FROM resource.tb_node_mst nm\r\n                      LEFT OUTER JOIN resource.tb_node_position_info np ON np.node_id = nm.node_id AND np.topology_type = '2'\r\n            where np.fx is not null\r\n            UNION \r\n            SELECT distinct on (em.tid, em.sysname, em.model)\r\n                 row_number() over () AS index\r\n                 , null as node_num\r\n                 , em.tid AS id\r\n                 , em.sysname  AS device_name\r\n                 , em.tid AS ip_addr\r\n                 , CASE model\r\n                 WHEN 'Utrans-6300p-H3' THEN '1'\r\n                 WHEN 'Utrans-6300p-V9' THEN '0'\r\n                 ELSE '2'\r\n                 END AS device_type\r\n                 , true as visible\r\n                 , np.fx as fx\r\n                 , np.fy  as fy\r\n             FROM nia.tb_equip_mst em\r\n                  LEFT OUTER JOIN resource.tb_node_position_info np ON np.node_id = em.tid AND np.topology_type= '2'\r\n            order by node_num\r\n        ) as node"
    ],
