            "SELECT  src_protocol,\n                src_port,\n                dst_protocol,\n                dst_port,\n                packet_bytes,\n                rank_order\n        FROM    ( SELECT src_protocol,\n                        src_port,\n                        dst_protocol,\n                        dst_port,\n                        SUM(packet_bytes) packet_bytes ,\n                        row_number() over (ORDER BY\n                        CASE\n                                WHEN src_protocol IS NULL\n                                AND     dst_protocol IS NULL\n                                THEN 0\n                                ELSE 2\n                        END DESC, SUM(packet_bytes) DESC) rank_order\n                FROM    gather.tb_mdb_sflow_traffic_day dt\n                WHERE   1=1\n                        AND dt.collect_timestamp   <=   CURRENT_DATE \n                        AND dt.collect_timestamp   >=   CURRENT_DATE - interval '5 days'\n                GROUP BY src_protocol,\n                        src_port,\n                        dst_protocol,\n                        dst_port ) dt\n                WHERE   1=1\n                    AND rank_order   <   101\n            LIMIT 50 OFFSET 0"
