        "sql": [
            "WITH TRAFFIC_DATA AS\n                ( SELECT NM.NODE_NUM, NM.NODE_NM, N.ID AS SDN_NODE_ID, PM.IF_NUM, I.ID AS SDN_IF_ID, I.IF_NAME, LT.TX_BIT_RATE, LT.RX_BIT_RATE, LT.TX_PKT_RATE, LT.RX_PKT_RATE, LT.MEASURED_DATETIME\n                FROM    IP_SDN.TB_LINK_TRAFFIC LT\n                INNER JOIN IP_SDN.TB_INTERFACE I   ON LT.IF_ID = I.ID\n                INNER JOIN RESOURCE.TB_PORT_MST PM ON PM.IF_ID = LOWER(I.IF_NAME)\n                INNER JOIN IP_SDN.TB_NODE N        ON I.NODE_ID = N.ID\n                INNER JOIN RESOURCE.TB_NODE_MST NM ON N.ID = NM.IP_SDN_ID::INT\n                WHERE   PM.NODE_NUM = NM.NODE_NUM \n                    AND LT.MEASURED_DATETIME BETWEEN NOW()::timestamp - interval '10 min' AND NOW()::timestamp\n                )\n        SELECT  T.NODE_NUM, \n                T.NODE_NM AS NODE_NAME, \n                T.SDN_NODE_ID, \n                T.IF_NUM,\n                T.SDN_IF_ID,\n                T.IF_NAME,\n                T.DIRECTION,\n                T.RX_BIT_RATE,\n                T.RX_PKT_RATE,\n                T.TX_BIT_RATE,\n                T.TX_PKT_RATE,\n                TO_CHAR(T.MEASURED_DATETIME, 'YYYY-MM-DD HH24:MI:SS') AS MEASURED_DATETIME,\n                CASE WHEN (SELECT 1\n                                        FROM    RCA.TB_ANOMALOUS_1MI_TRAFFIC\n                                        WHERE   STRRESID = T.NODE_NUM AND STRIFID = T.IF_NUM AND MEASURED_DATETIME = T.MEASURED_DATETIME \n                                            AND MEASURED_DATETIME BETWEEN NOW()::timestamp - interval '10 min' AND NOW()::timestamp\n                            ) =1 THEN TRUE ELSE FALSE\n                END AI_RESULT\n        FROM   ( SELECT NODE_NUM, NODE_NM, SDN_NODE_ID, IF_NUM, SDN_IF_ID, IF_NAME, 'IN' AS DIRECTION, RX_BIT_RATE, RX_PKT_RATE, 0 AS TX_BIT_RATE, 0 AS TX_PKT_RATE, MEASURED_DATETIME\n                FROM    TRAFFIC_DATA\n                UNION ALL\n                SELECT  NODE_NUM, NODE_NM, SDN_NODE_ID, IF_NUM, SDN_IF_ID, IF_NAME, 'OUT' AS DIRECTION, 0 AS RX_BIT_RATE, 0 AS RX_PKT_RATE, TX_BIT_RATE, TX_PKT_RATE, MEASURED_DATETIME\n                FROM    TRAFFIC_DATA ) T\n        ORDER BY MEASURED_DATETIME DESC\n            LIMIT 50 OFFSET 0"
        ],
