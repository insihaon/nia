        "sql": [
            "SELECT\n            ROW_NUMBER() OVER () AS ROWNUM\n            , *\n        FROM (\n        SELECT DISTINCT\n        BL.SRC_NODE_NUM\n        , BL.SRC_NODE_ID\n        , BL.SRC_IF_NUM\n        , BL.SRC_IF_ID\n        , SP.IF_NM AS SRC_IF_NAME\n        , BL.SRC_IP_ADDR\n        , BL.SRC_MAC_ADDR\n        , BL.DEST_NODE_NUM\n        , BL.DEST_NODE_ID\n        , BL.DEST_IF_NUM\n        , BL.DEST_IF_ID\n        , DP.IF_NM AS DEST_IF_NAME\n        , BL.DEST_IP_ADDR\n        , BL.DEST_MAC_ADDR\n        , BL.PREFIX\n        , BL.BANDWIDTH\n        , BL.CIRCUIT_NUM\n        , BL.LINK_TYPE\n        , BL.VLAN \"VLAN\"\n        , BL.TAG \"TAG\"\n        , BL.LINK_DESC\n        , TO_CHAR(BL.CHNG_DATETIME, 'YYYY-MM-DD HH24:MI:SS') AS CHNG_DATETIME\n        FROM RESOURCE.TB_BACKBONE_LINK BL\n        LEFT OUTER JOIN RESOURCE.TB_PORT_MST SP ON SP.NODE_ID = BL.SRC_NODE_ID AND SP.IF_ID = BL.SRC_IF_ID\n        LEFT OUTER JOIN RESOURCE.TB_PORT_MST DP ON DP.NODE_ID = BL.DEST_NODE_ID AND DP.IF_ID = BL.DEST_IF_ID\n        WHERE 1=1\n        ) AS link"
        ],
