        "sql": [
            "WITH \n        series AS (\n            SELECT generate_series (\n                DATE_TRUNC('month', TO_DATE('2023-01-01T15:00:00.000Z', 'YYYY-MM')::date),\n                DATE_TRUNC('month', TO_DATE('2023-01-01T15:00:00.000Z', 'YYYY-MM')::date) + ('1 ' || 'month')::INTERVAL - ('1 ' || 'day')::INTERVAL,\n            ('1 '|| 'day')::INTERVAL\n            ) AS series_time\n        )\n        SELECT\n            TO_CHAR(series.series_time, 'YYYY-MM-DD') AS series_time,\n            COALESCE(COUNT(CASE WHEN TPD.self_process_group IN ('SO') THEN 1 END), 0) AS SO_TOTALCOUNT,\n            COALESCE(COUNT(CASE WHEN TPD.self_process_group IN ('SO') AND TPD.clos_type = 'A' AND TPD.clos_status = 'Y' THEN 1 END), 0) AS SO_COUNT,\n            COALESCE(COUNT(CASE WHEN TPD.self_process_group IN ('ST') THEN 1 END), 0) AS ST_TOTALCOUNT,\n            COALESCE(COUNT(CASE WHEN TPD.self_process_group IN ('ST') AND TPD.clos_type = 'A' AND TPD.clos_status = 'Y' THEN 1 END), 0) AS ST_COUNT\n        FROM series\n        LEFT JOIN nia.tb_auto_treat_process_dtl TPD ON DATE_TRUNC('day', TPD.occur_time) = series.series_time\n        GROUP BY series_time\n        ORDER BY series_time"
        ],
