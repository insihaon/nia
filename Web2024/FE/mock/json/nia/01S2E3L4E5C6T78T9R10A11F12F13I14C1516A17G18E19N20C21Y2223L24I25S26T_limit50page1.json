        "sql": [
            "SELECT\n            src_ip,\n            src_nren_id,\n            CASE\n                WHEN src_nren_name IS NULL OR src_nren_name = '' THEN '기타'\n                ELSE src_nren_name\n            END AS src_nren_name,\n            src_country_code,\n            dst_ip,\n            dst_nren_id,\n            CASE\n                WHEN dst_nren_name IS NULL OR dst_nren_name = '' THEN '기타'\n                ELSE dst_nren_name\n        END AS dst_nren_name,\n            dst_country_code,\n            packet_bytes,\n            row_num\n        FROM (\n            SELECT\n                src_ip,\n                src_nren_id,\n                src_nren_name,\n                src_country_code,\n                dst_ip,\n                dst_nren_id,\n                dst_nren_name,\n                dst_country_code,\n                SUM(packet_bytes) AS packet_bytes,\n                row_number() OVER (\n                    ORDER BY\n                        SUM(packet_bytes) desc,\n                        CASE\n                            WHEN src_nren_id IS NULL AND dst_nren_id IS NULL THEN 0\n                            ELSE 2\n                        END desc\n                ) AS row_num\n            FROM\n                gather.tb_mdb_sflow_traffic_day dt\n            WHERE\n                1=1\n                AND dt.collect_timestamp   <=   CURRENT_DATE\n                AND dt.collect_timestamp   >=   CURRENT_DATE - INTERVAL '5 days'\n            GROUP BY\n                src_ip,\n                src_nren_id,\n                src_nren_name,\n                src_country_code,\n                dst_ip,\n                dst_nren_id,\n                dst_nren_name,\n                dst_country_code\n        ) AS subquery\n        WHERE 1=1\n                AND row_num   <   101\n            LIMIT 50 OFFSET 0"
        ],
