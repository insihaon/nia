            "SELECT\n            TUO.NREN_ID,\n            TUO.NREN_NAME,\n            TUO.NODE_ID,\n            TUO.IF_ID,\n            IF.IF_NM,\n            COALESCE(REGEXP_REPLACE((REVERSE((REGEXP_MATCH(REVERSE(IF.IF_NM), E'G[0-9]+'))[1])), 'G', ''), CAST(CAST(TUO.BANDWIDTH AS BIGINT) / 1000000000 AS BIGINT)::CHAR) AS BANDWIDTH,\n            TUO.CUSTOMER_ID,\n            TUO.EMAIL,\n            ROW_NUMBER() OVER (ORDER BY NREN_ID) AS ROWNUM\n        FROM RESOURCE.TB_USER_ORGAN TUO\n        LEFT OUTER JOIN (SELECT DISTINCT NODE_ID, IF_ID, IF_NM FROM RESOURCE.TB_PORT_MST) IF ON IF.NODE_ID = TUO.NODE_ID AND IF.IF_ID = TUO.IF_ID\n        WHERE 1=1\n        ORDER BY NREN_ID\n            LIMIT 50 OFFSET 0"
