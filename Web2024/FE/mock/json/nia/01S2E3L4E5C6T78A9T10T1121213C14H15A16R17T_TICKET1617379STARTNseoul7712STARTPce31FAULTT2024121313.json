        "sql": [
            "SELECT  \n        N.ID AS SDN_NODE_ID,\n        NM.NODE_NUM AS STRRESID,\n        NM.NODE_NM AS STRRESNM, \n        I.ID AS SDN_IF_ID,\n        I.IF_NAME AS STRIFNM, \n        PM.IF_NUM AS STRIFID, \n        LT.TX_BIT_RATE AS FLTBPS_OUT,\n        LT.RX_BIT_RATE AS FLTBPS_IN,\n        LT.TX_PKT_RATE AS FLTPPS_OUT,\n        LT.RX_PKT_RATE AS FLTPPS_IN,\n        ROUND(AR.FLTBPSIN_THRESHOLD_UPPER::NUMERIC, 2) AS IN_THRESHOLD_UPPER, -- 추가된 필드\n        UO.NREN_ID,\n        UO.NREN_NAME,\n        TO_CHAR(LT.MEASURED_DATETIME, 'YYYY-MM-DD HH24:MI:SS') AS MEASURED_DATETIME,\n        LT.ID\n    FROM \n        IP_SDN.TB_LINK_TRAFFIC LT\n    INNER JOIN \n        IP_SDN.TB_INTERFACE I ON LT.IF_ID = I.ID\n    INNER JOIN \n        RESOURCE.TB_PORT_MST PM ON PM.IF_ID = LOWER(I.IF_NAME)\n    INNER JOIN \n        IP_SDN.TB_NODE N ON I.NODE_ID = N.ID\n    INNER JOIN \n        RESOURCE.TB_NODE_MST NM ON N.ID = NM.IP_SDN_ID::INT\n    LEFT OUTER JOIN \n        RESOURCE.TB_USER_ORGAN UO ON UO.NODE_ID = NM.NODE_ID AND UO.IF_ID = PM.IF_ID\n    LEFT OUTER JOIN \n        rca.tb_anomalous_ai_result AR \n        ON AR.STRIFID = PM.IF_NUM \n        AND AR.STRRESID = PM.NODE_NUM \n        AND AR.MEASURED_DATETIME BETWEEN '2024-12-13 13:48:00'::TIMESTAMP - interval '10 min' \n                                    AND '2024-12-13 13:48:00'::TIMESTAMP + interval '10 min' -- 시간 조건 추가\n    WHERE   \n        PM.NODE_NUM = NM.NODE_NUM\n        AND NM.NODE_NM = 'seoul-7712'\n        AND I.IF_NAME = 'ce3/1'\n        AND LT.MEASURED_DATETIME BETWEEN '2024-12-13 13:48:00'::TIMESTAMP - interval '10 min' \n                                    AND '2024-12-13 13:48:00'::TIMESTAMP + interval '10 min' -- 기존 시간 조건\n    ORDER BY \n        LT.ID"
        ],
