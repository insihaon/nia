        "sql": [
            "SELECT\n        \tCASE \n\t        \tWHEN tpd.SELF_PROCESS_TYPE = 'S' THEN tpd.ALARMNO\n\t            ELSE tpd.TICKET_ID\n\t            END AS TICKET_ID\n        \t, TO_CHAR(OCCUR_TIME, 'YYYY-MM-DD HH24:MI:SS') AS OCCUR_TIME\n        \t, TO_CHAR(CLOS_TIME, 'YYYY-MM-DD HH24:MI:SS') AS CLOS_TIME\n        \t, CASE WHEN tpd.TICKET_TYPE IS NULL THEN 'SYSLOG'\n\t        \tELSE tpd.TICKET_TYPE\n\t        \tEND AS TICKET_TYPE\n        \t, SELF_PROCESS_TYPE \n        \t, CASE \n\t        \tWHEN tpd.SELF_PROCESS_TYPE = 'S' THEN tss.FAULT_DETAIL_CONTENT\n\t            ELSE ts.FAULT_DETAIL_CONTENT\n\t            END AS FAULT_DETAIL_CONTENT\n\t        , CLOS_TYPE \n\t        , CLOS_STATUS \n            , TO_CHAR((\n                SELECT FAULT_TIME\n                FROM rca.tb_rca_ticket_current rtc\n                WHERE rtc.ticket_id = tpd.ticket_id\n            ), 'YYYY-MM-DD HH24:MI:SS') AS FAULT_TIME\n            , TS.TICKET_RESULT\n            , (\n                SELECT  ZERO1_ENTROPY\n                FROM rca.tb_rca_ticket_current rtc\n                WHERE tpd.ticket_id = rtc.ticket_id\n            ) ZERO1_ENTROPY\n       \tFROM nia.tb_auto_treat_process_dtl tpd\n       \tLEFT JOIN nia.tb_sop ts ON tpd.ticket_id = ts.ticket_id \n       \tLEFT JOIN nia.tb_syslog_sop tss ON tpd.alarmno = tss.alarmno\n       \tWHERE 1=1\n                    AND tpd.OCCUR_TIME   >=   '2024-12-17'::TIMESTAMP\n                    AND tpd.OCCUR_TIME   <   '2024-12-17'::TIMESTAMP + ('1'||'day')::INTERVAL\n                    AND tpd.SELF_PROCESS_GROUP = 'SO'\n       \tORDER BY TPD.OCCUR_TIME DESC\n            LIMIT 100 OFFSET 0"
        ],
