# just a flag
NODE_ENV = production
BASE_URL = /datahub/portal

# base api
VUE_APP_PROJECT = datahub
VUE_APP_TITLE = HUB
VUE_APP_ANONYMOUS_MODE = true
VUE_APP_ERROR_PAGE = true
VUE_APP_ONLY_IFRAME = true
VUE_APP_HTTP_TIMEOUT = 60
VUE_APP_USE_SESSION_SIGNIN = true

# use cookie
VUE_USE_AUTH_COOKIE = true