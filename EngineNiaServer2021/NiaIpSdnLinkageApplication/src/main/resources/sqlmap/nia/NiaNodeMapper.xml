<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.nia.ip.sdn.linkage.mapper.nia.NiaNodeMapper">

    <insert id="insertNodeYd" parameterType="java.util.HashMap">
        <if test="nodeVoList.size != 0">
            INSERT INTO IP_SDN.TB_NODE_YD
            (
                ID, NODE_NAME, LOOP_BACK_ADDR, MGMT_ADDR
            )
            VALUES
            <foreach collection="nodeVoList" item="item" separator=",">
            (
                #{item.id}, #{item.nodeName}, #{item.loopBackAddr}, #{item.mgmtAddr}
            )
            </foreach>
        </if>
    </insert>

    <insert id="insertNode">
        INSERT INTO IP_SDN.TB_NODE
        SELECT * FROM IP_SDN.TB_NODE_YD
    </insert>

    <delete id="deleteNodeYd">
        TRUNCATE TABLE IP_SDN.TB_NODE_YD
    </delete>

    <delete id="deleteNode">
        TRUNCATE TABLE IP_SDN.TB_NODE
    </delete>
</mapper>


