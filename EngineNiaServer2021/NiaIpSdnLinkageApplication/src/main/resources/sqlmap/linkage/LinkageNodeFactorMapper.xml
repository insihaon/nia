<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.nia.ip.sdn.linkage.mapper.linkage.LinkageNodeFactorMapper">

    <select id="selectMaxId" resultType="com.nia.ip.sdn.linkage.vo.NodeFactorVo">
        SELECT MAX(ID) AS ID FROM optroute.nodefactor
    </select>

    <select id="selectNodeFactorList" resultType="com.nia.ip.sdn.linkage.vo.NodeFactorVo" parameterType="int">
        SELECT Id, CpuUsage, MemUsage, Node_Id, MeasuredDateTime
          FROM optroute.nodefactor
         WHERE Id <![CDATA[ > ]]> #{id}
         ORDER BY Id
    </select>
</mapper>


