<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.nia.alarm.simulator.mapper.AlarmMapper">

	<select id="selectAlarmList" resultType="com.nia.alarm.simulator.vo.AlarmVo">
		SELECT ALARMNO, SYSNAME, EQUIPTYPE, ALARMTIME, RECEIVETIME, ALARMLOC, ALARMMSG, UNIT, ALARMLEVEL
		  FROM NIA.TB_ALARM_TMP_MST
		ORDER BY RECEIVETIME DESC
	</select>

	<delete id="deleteAlarm" parameterType="string">
		DELETE FROM NIA.TB_ALARM_TMP_MST WHERE ALARMNO = #{alarmno}
	</delete>
</mapper>


