<?xml version="1.0" encoding="UTF-8"?>

<configuration>
	<property name="LOG_TEMP" value="/home/codej8888/server/spring/log/" />
	<include resource="org/springframework/boot/logging/logback/base.xml"/>
 
	<appender name="engineApplicationInfo"
		class="ch.qos.logback.core.rolling.RollingFileAppender">
		<prudent>true</prudent>
		<rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
			<fileNamePattern>/home/codej8888/server/logs/engine_application.%d{yyyy-MM-dd}.log</fileNamePattern>
			<maxHistory>30</maxHistory>
		</rollingPolicy>
		<filter class="ch.qos.logback.classic.filter.ThresholdFilter">
			<level>INFO</level>
		</filter>
 
		<encoder>
			<pattern>%d{yyyy:MM:dd HH:mm:ss.SSS} %-5level --- [%thread] %logger{35} : %msg %n</pattern>
		</encoder>
	</appender>
	
	<appender name="engineApplicationError"
		class="ch.qos.logback.core.rolling.RollingFileAppender">
		<prudent>true</prudent>
		<rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
			<fileNamePattern>/home/codej8888/server/logs/engine_application_error.%d{yyyy-MM-dd}.log</fileNamePattern>
			<maxHistory>30</maxHistory>
		</rollingPolicy>
		<filter class="ch.qos.logback.classic.filter.ThresholdFilter">
			<level>ERROR</level>
		</filter>
 
		<encoder>
			<pattern>%d{yyyy:MM:dd HH:mm:ss.SSS} %-5level --- [%thread] %logger{35} : %msg %n</pattern>
		</encoder>
	</appender>
 
	<logger name="org.springframework" level="INFO"/>
	<logger name="com.nia.engine" level="INFO"/>
 
	<root level="INFO">
		<appender-ref ref="engineApplicationInfo"/>
	</root>
	<root level="ERROR">
		<appender-ref ref="engineApplicationError"/>
	</root>
</configuration>