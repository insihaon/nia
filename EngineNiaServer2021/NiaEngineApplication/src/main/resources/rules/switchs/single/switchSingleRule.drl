end


rule "SWITCH_PORT_DOWN"
salience 1000
lock-on-active
no-loop
    when
        //conditions
        flagTF : Flag(flag == false)
        $a1 : BasicAlarmVo(alarmmsg == RcaCodeInfo.ALARM_SWITCH_PORT_DOWN)
    then
        //actions
        rcaResult.setRcaResultCode("SWITCH_PORT_DOWN");
        rcaResult.setFaultDetailCode("PORT 다운");
        rcaResult.setDomainCode(RcaCodeInfo.DOMAIN_SWITCH);
        rcaResult.setRcaResultTypeCode(RcaCodeInfo.RCA_RESULT_SWITCH_FAIL);
        rcaResult.addRelatedAlarm($a1);

        flagTF.setFlag(true);
        update(flagTF);
end

