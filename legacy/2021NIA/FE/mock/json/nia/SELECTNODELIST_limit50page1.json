        "encrypt": false,
        "sql": [
            "SELECT\n            ROW_NUMBER() OVER (ORDER BY NODE_NUM) AS ROWNUM,\n            node.*\n        FROM (\n            SELECT\n                TNM.NODE_NUM,\n                TNM.NODE_ID,\n                TNM.NODE_NM,\n                TNM.MODEL_NUM,\n                TNM.MODEL_ID,\n                CODE.CODE_NM,\n                TNM.IP_ADDR,\n                TNM.MAC_ADDR,\n                TNM.ADMIN_YN,\n                CASE\n                \tWHEN ADMIN_YN = 'W' THEN '사용'\n                \tELSE '미사용' \n                    \tEND AS ADMIN_YN_INFO,\n                TNM.PRIMARY_GB,\n                TNM.SNMP_VER,\n                TNM.SNMP_COMMUNITY,\n                TNM.SNMP_PORT,\n                TNM.LATITUDE,\n                TNM.LONGITUDE,\n                TNM.NETCONF_PORT,\n                TNM.NETCONF_ID,\n                TNM.NETCONF_PW,\n                TNM.NETCONF_TYPE,\n                TNM.NODE_DIVISION,\n                TNM.VENDOR,\n                TNM.SFLOW_IP,\n                TO_CHAR(TNM.CHNG_DATETIME, 'YYYY-MM-DD HH:MI:SS') AS CHNG_DATETIME\n                FROM RESOURCE.TB_NODE_MST TNM\n                LEFT OUTER JOIN RESOURCE.TB_CODE CODE ON (TNM.MODEL_ID = CODE.CODE_ID)\n                WHERE 1=1\n                ORDER BY CHNG_DATETIME ASC\n        ) AS node\n        ORDER BY NODE_NUM\n            LIMIT 50 OFFSET 0"
        ],
