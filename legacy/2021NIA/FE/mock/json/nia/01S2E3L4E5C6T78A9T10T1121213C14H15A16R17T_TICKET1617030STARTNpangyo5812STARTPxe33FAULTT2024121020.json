        "sql": [
            "SELECT  N.ID AS SDN_NODE_ID\n                , NM.NODE_NUM AS STRRESID\n                , NM.NODE_NM AS STRRESNM \n                , I.ID AS SDN_IF_ID\n                , I.IF_NAME AS STRIFNM \n                , PM.IF_NUM AS STRIFID \n                , LT.TX_BIT_RATE AS FLTBPS_OUT\n                , LT.RX_BIT_RATE AS FLTBPS_IN\n                , LT.TX_PKT_RATE AS FLTPPS_OUT\n                , LT.RX_PKT_RATE AS FLTPPS_IN \n                , UO.NREN_ID\n                , UO.NREN_NAME\n                , TO_CHAR(LT.MEASURED_DATETIME, 'YYYY-MM-DD HH24:MI:SS') AS MEASURED_DATETIME\n                , LT.ID\n        FROM    IP_SDN.TB_LINK_TRAFFIC LT\n        INNER JOIN IP_SDN.TB_INTERFACE I          ON LT.IF_ID = I.ID\n        INNER JOIN RESOURCE.TB_PORT_MST PM        ON PM.IF_ID = LOWER(I.IF_NAME)\n        INNER JOIN IP_SDN.TB_NODE N               ON I.NODE_ID = N.ID\n        INNER JOIN RESOURCE.TB_NODE_MST NM        ON N.ID = NM.IP_SDN_ID::INT\n        LEFT OUTER JOIN RESOURCE.TB_USER_ORGAN UO ON UO.NODE_ID = NM.NODE_ID AND     UO.IF_ID = PM.IF_ID\n        WHERE   PM.NODE_NUM = NM.NODE_NUM\n            AND     NM.NODE_NM = 'pangyo-5812'\n            AND     I.IF_NAME = 'xe33'\n            AND     LT.MEASURED_DATETIME BETWEEN '2024-12-10 20:29:00'::TIMESTAMP - interval '10 min' AND '2024-12-10 20:29:00'::TIMESTAMP + interval '10 min'\n        ORDER BY LT.ID"
        ],
