        "sql": [
            "WITH DATEREGDATE_DATA AS (\n            SELECT DISTINCT DATEREGDATE\n            FROM IP_YD.XE_SFLOW_LOG\n             WHERE (  DATEREGDATE BETWEEN '2024-03-31 19:09:53'::TIMESTAMP - INTERVAL '1 HOUR' AND '2024-03-31 19:09:53'::TIMESTAMP + INTERVAL '1 HOUR' ) \n            ORDER BY DATEREGDATE\n        )\n        SELECT\n            COLLECT_TIME\n\t        , STRBYTES_COL\n        \t, STRCOUNTS\n        FROM\n        (\n            SELECT\n                CASE WHEN DD.DATEREGDATE = XSL.DATEREGDATE THEN XSL.STRBYTES_COL\n                    ELSE '0'\n                    END STRBYTES_COL\n                , CASE WHEN DD.DATEREGDATE = XSL.DATEREGDATE THEN STRCOUNTS\n                    ELSE '0'\n                    END STRCOUNTS\n                , DD.DATEREGDATE AS COLLECT_TIME\n            FROM DATEREGDATE_DATA DD\n            LEFT JOIN (\n                SELECT STRCOUNTS, STRBYTES_COL, DATEREGDATE\n                FROM ip_yd.xe_sflow_log\n                 WHERE (  DATEREGDATE = '2024-03-31 19:09:53'::TIMESTAMP\n                            AND STRSENDERIP = (\n                                SELECT DISTINCT STRSENDERIP \n                                FROM RCA.TB_NOXIOUS_TRAFFIC \n                                WHERE TICKET_ID = '1599545'\n                            )\n                            AND STRS_IP  = '142.250.207.101'\n                            AND STRS_PORT  = '443'\n                            AND STRD_IP  = '103.22.220.100'\n                            AND STRD_PORT  = '59228' ) \n            ) XSL ON 1=1\n        ) T\n        GROUP BY COLLECT_TIME, STRBYTES_COL, STRCOUNTS"
        ],
