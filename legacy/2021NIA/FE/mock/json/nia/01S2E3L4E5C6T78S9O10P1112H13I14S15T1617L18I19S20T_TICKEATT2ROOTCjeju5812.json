        "sql": [
            "SELECT \n        \tSOP.SOP_ID ,\n            SOP.TICKET_ID ,\n            SOP.TICKET_TYPE ,\n            CASE WHEN SOP.TICKET_TYPE = 'ATT2' THEN '이상 트래픽'\n            WHEN SOP.TICKET_TYPE = 'NTT' THEN '유해 트래픽'\n            WHEN SOP.TICKET_TYPE = 'NFTT' THEN '장비 과부하 장애'\n            WHEN SOP.TICKET_TYPE = 'FTT' THEN '비장애'\n            ELSE '장애' END AS TICKETTYPE,\n            SOP.TICKET_RESULT ,\n            SOP.STATUS ,\n            TO_CHAR(SOP.REQUEST_TIME, 'YYYY-MM-DD HH24:MI:SS') AS REQUEST_TIME,\n            TO_CHAR(SOP.RECEIVE_TIME, 'YYYY-MM-DD HH24:MI:SS') AS RECEIVE_TIME,\n            SOP.DETAIL ,\n            SOP.FAULT_CLASSIFY ,\n            SOP.FAULT_TYPE ,\n            SOP.FAULT_DETAIL_CONTENT ,\n            SOP.ETC_CONTENT ,\n            SOP.AI_ACCURACY ,\n            AL.ROOT_CAUSE_SYSNAMEA ,\n            AL.ROOT_CAUSE_SYSNAMEZ ,\n            AL.ROOT_CAUSE_PORTA ,\n            AL.ROOT_CAUSE_PORTZ ,\n            NODEA.IP_ADDR AS IP_ADDRA ,\n            NODEZ.IP_ADDR AS IP_ADDRZ ,\n            TC.ROOT_CAUSE_TYPE AS ROOT_CAUSE_TYPE ,\n            TO_CHAR(TC.FAULT_TIME, 'YYYY-MM-DD HH24:MI:SS') AS FAULT_TIME ,\n            SOP.HANDLING_ACK_USER AS HANDLING_ACK_USER ,\n            TO_CHAR(SOP.HANDLING_ACK_TIME, 'YYYY-MM-DD HH24:MI:SS') AS HANDLING_ACK_TIME ,\n            SOP.HANDLING_FIN_USER AS HANDLING_FIN_USER ,\n            TO_CHAR(SOP.HANDLING_FIN_TIME, 'YYYY-MM-DD HH24:MI:SS') AS HANDLING_FIN_TIME \n        FROM nia.tb_sop SOP\n        LEFT JOIN rca.tb_rca_ticket_al_current AL ON SOP.TICKET_ID = AL.TICKET_ID\n        LEFT JOIN rca.tb_rca_ticket_current TC    ON AL.TICKET_ID = TC.TICKET_ID\n        LEFT JOIN resource.tb_node_mst NODEA ON NODEA.node_id = AL.ROOT_CAUSE_SYSNAMEA\n        LEFT JOIN resource.tb_node_mst NODEZ ON NODEZ.node_id = AL.ROOT_CAUSE_SYSNAMEZ\n        WHERE 1=1\n            AND AL.INSERT_TIME   >   now() - INTERVAL '7' day\n            AND TC.TICKET_TYPE IN ('ATT2')\n            AND AL.ROOT_CAUSE_SYSNAMEA   =   'jeju-5812'\n            AND request_time   >   now() - INTERVAL '1' month\n        ORDER BY SOP.REQUEST_TIME DESC"
        ],
