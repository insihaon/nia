        "sql": [
            "SELECT  SYSLOG.ALARMNO\n                , SYSLOG.NODE_NM\n                , SYSLOG.NODE_NUM\n                , SYSLOG.ALARMLOC\n                , TO_CHAR(SYSLOG.ALARMTIME, 'YYYY-MM-DD HH24:MI:SS') AS ALARMTIME\n                , SYSLOG.ALARMMSG\n                , SYSLOG.ETC\n                , SOP.PROC_STATUS\n                , SOP.FAULT_CLASSIFY\n                , SOP.FAULT_TYPE\n                , SOP.FAULT_DETAIL_CONTENT\n                , SOP.ETC_CONTENT\n                , TO_CHAR(SOP.ALARM_OCCUR_TIME, 'YYYY-MM-DD HH24:MI:SS') AS ALARM_OCCUR_TIME\n                , TO_CHAR(SOP.HANDLING_FIN_TIME, 'YYYY-MM-DD HH24:MI:SS') AS HANDLING_FIN_TIME\n                , SOP.HANDLING_FIN_USER\n                , SOP.STATUS\n        FROM    nia.tb_syslog_sop SOP\n        INNER JOIN rca.tb_syslog_alarm_mst SYSLOG ON SOP.ALARMNO = SYSLOG.ALARMNO\n         WHERE (  SOP.HANDLING_FIN_TIME  >  NOW() - INTERVAL '1' MONTH\n                    AND SYSLOG.NODE_NM = 'busan-5812' ) \n        ORDER BY SYSLOG.ALARMTIME DESC\n            LIMIT 100 OFFSET 0"
