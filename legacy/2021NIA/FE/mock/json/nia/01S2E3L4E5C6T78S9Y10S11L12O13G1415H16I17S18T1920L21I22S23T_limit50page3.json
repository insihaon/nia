            "SELECT  sysDialog.alarmno,\n                sysDialog.alarmtime,\n                TO_CHAR(sysDialog.alarmtime, 'YYYY-MM-DD HH24:MI:SS') AS syslog_alarmtime,\n                sysDialog.node_num,\n                sysDialog.node_nm,\n                sysDialog.alarmmsg,\n                sysDialog.alarmlvl,\n                sysDialog.etc,\n                sysDialog.rule_id,\n                sysDialog.alarmloc,\n                CASE WHEN sysDialog.status = 'INIT' THEN '발생'\n                WHEN sysDialog.status = 'FIN' THEN '수동 마감'\n                WHEN sysDialog.status = 'AUTO_FIN' THEN '자동 마감'\n                ELSE '-'\n                END AS status\n        FROM    rca.tb_syslog_alarm_mst sysDialog\n             WHERE sysDialog.alarmtime BETWEEN NOW()::timestamp - interval '30 day' AND NOW()::timestamp\n                ORDER BY sysDialog.alarmno DESC  \n            LIMIT 50 OFFSET 100"
