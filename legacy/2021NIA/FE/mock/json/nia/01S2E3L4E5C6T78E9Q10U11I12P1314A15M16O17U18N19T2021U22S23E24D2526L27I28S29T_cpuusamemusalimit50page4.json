        "sql": [
            "SELECT  A.NODE_NUM AS NODE_NUM,\n                    A.SDN_NODE_ID AS SDN_NODE_ID,\n                    A.NODE_NM AS NODE_NM,\n                    CASE WHEN A.CPU_USAGE = -1 THEN A.CPU_USAGE ELSE TRUNC(A.CPU_USAGE::NUMERIC, 3) * 100 END AS CPU_USAGE,\n                    CASE WHEN A.MEM_USAGE = -1 THEN A.MEM_USAGE ELSE TRUNC(A.MEM_USAGE::NUMERIC, 3) * 100 END AS MEM_USAGE,\n                    TO_CHAR(A.MEASURED_DATETIME, 'YYYY-MM-DD HH24:MI:SS') AS MEASURED_DATETIME,\n                    CASE WHEN TN.STRRESID IS NOT NULL THEN TRUE ELSE FALSE\n                    END AS AI_RESULT\n            FROM   ( SELECT NM.NODE_NUM,\n                            N.ID AS SDN_NODE_ID,\n                            NM.NODE_NM,\n                            NF.CPU_USAGE,\n                            NF.MEM_USAGE,\n                            NF.MEASURED_DATETIME\n                    FROM    IP_SDN.TB_NODEFACTOR NF\n                    INNER JOIN IP_SDN.TB_NODE N        ON NF.NODE_ID = N.ID\n                    INNER JOIN RESOURCE.TB_NODE_MST NM ON N.ID = NM.IP_SDN_ID::INT\n                    WHERE   1=1 \n                        AND NF.MEASURED_DATETIME BETWEEN NOW()::timestamp - interval '30 min' AND NOW()::timestamp\n                        ORDER BY MEASURED_DATETIME DESC\n                    ) A\n            LEFT OUTER JOIN RCA.TB_NODEFACTOR TN \n                ON TN.STRRESID = A.NODE_NUM \n                    AND TN.MEASURED_DATETIME = A.MEASURED_DATETIME\n            LIMIT 50 OFFSET 150"
        ],
