        "encrypt": false,
        "sql": [
            "SELECT DISTINCT\n        ALARMNO,\n        TICKET_ID,\n        CLUSTERNO,\n        NODE_NUM,\n        NODE_NM,\n        ALARMLOC,\n        T.TICKET_TYPE,\n        TO_CHAR(ALARMTIME, 'YYYY-MM-DD HH24:MI:SS') AS ALARMTIME,\n        TO_CHAR(FAULT_TIME, 'YYYY-MM-DD HH24:MI:SS') AS FAULT_TIME,\n        PORT,\n        ALARMMSG,\n        FAULT_TYPE,\n        ALARMMSG_ORIGINAL,\n        TICKET_RCA_RESULT_CODE,\n        STATUS,\n        TICKET_RCA_RESULT_DTL_CODE,\n        TOTAL_RELATED_ALARM_CNT,\n        ROOT_CAUSE_SYSNAMEA,\n        ROOT_CAUSE_SYSNAMEZ,\n        ROOT_CAUSE_PORTA,\n        ROOT_CAUSE_PORTZ,\n        ZERO1_ENTROPY,\n        IP_ADDR,\n        AI_ACCURACY\n    FROM (\n        SELECT \n            ACM.ALARMNO,\n            TC.TICKET_ID,\n            ACM.CLUSTERNO,\n            NULL NODE_NUM,\n            ACM.SYSNAME AS NODE_NM,\n            ACM.ALARMLOC,\n            TC.TICKET_TYPE,\n            TC.root_cause_type AS FAULT_TYPE,\n            ACM.ALARMTIME AS ALARMTIME,\n            NULL FAULT_TIME,\n            ACM.ALARMMSG,\n            ACM.PORT,\n            ACM.ALARMMSG_ORIGINAL,\n            TC.STATUS,\n            TC.TICKET_RCA_RESULT_CODE,\n            TC.TICKET_RCA_RESULT_DTL_CODE,\n            NULL TOTAL_RELATED_ALARM_CNT,\n            AL.ROOT_CAUSE_SYSNAMEA,\n            AL.ROOT_CAUSE_SYSNAMEZ,\n            AL.ROOT_CAUSE_PORTA,\n            AL.ROOT_CAUSE_PORTZ,\n            TC.ZERO1_ENTROPY,\n            NM.IP_ADDR AS IP_ADDR,\n            SOP.AI_ACCURACY\n        FROM (\n            SELECT \n                ACM.ALARMNO,\n                MAX(ACM.CLUSTERNO) AS CLUSTERNO,\n                ACM.SYSNAME,\n                ACM.ALARMTIME AS ALARMTIME,\n                ACM.CLEARTIME,\n                ACM.ALARMLOC,\n                ACM.ALARMMSG,\n                ACM.ALARMLEVEL,\n                ACM.PORT,\n                ACM.ALARMMSG_ORIGINAL\n            FROM rca.tb_alarm_cur_mst ACM\n            WHERE ALARMNO LIKE 'I%'\n                AND ALARMTIME   >   now() - INTERVAL '7' DAY\n            GROUP BY ACM.ALARMNO, ACM.SYSNAME, ACM.ALARMTIME, ACM.CLEARTIME, ACM.ALARMLOC, ACM.ALARMMSG, ACM.ALARMLEVEL, ACM.PORT, ACM.ALARMMSG_ORIGINAL\n        ) ACM\n        LEFT JOIN rca.tb_rca_ticket_current TC ON ACM.clusterno = TC.cluster_no\n        LEFT JOIN rca.tb_rca_ticket_al_current AL ON TC.TICKET_ID = AL.TICKET_ID\n        LEFT OUTER JOIN resource.tb_node_mst NM ON NM.NODE_ID = AL.ROOT_CAUSE_SYSNAMEA\n        LEFT JOIN nia.tb_sop SOP ON TC.TICKET_ID = SOP.TICKET_ID\n        UNION ALL\n        SELECT\n            NULL ALARMNO,\n            TC.TICKET_ID,\n            CLUSTER_NO,\n            nm.node_num AS NODE_NUM,\n            nm.node_nm AS NODE_NM,\n            pt.if_id AS ALARMLOC,\n            TC.TICKET_TYPE,\n            TC.root_cause_type AS FAULT_TYPE,\n            TICKET_GENERATION_TIME AS ALARMTIME,\n            FAULT_TIME,\n            TC.root_cause_type AS ALARMMSG,\n            NULL PORT,\n            NULL ALARMMSG_ORIGINAL,\n            TC.STATUS,\n            TC.TICKET_RCA_RESULT_CODE,\n            TC.TICKET_RCA_RESULT_DTL_CODE,\n            TOTAL_RELATED_ALARM_CNT,\n            ROOT_CAUSE_SYSNAMEA,\n            ROOT_CAUSE_SYSNAMEZ,\n            ROOT_CAUSE_PORTA,\n            ROOT_CAUSE_PORTZ,\n            TC.ZERO1_ENTROPY,\n            NM.IP_ADDR AS IP_ADDR,\n            SOP.AI_ACCURACY\n        FROM rca.tb_rca_ticket_current TC\n        INNER JOIN rca.tb_rca_ticket_al_current AL ON TC.TICKET_ID = AL.TICKET_ID\n        INNER JOIN resource.tb_port_mst PT ON AL.ROOT_CAUSE_PORTA = PT.IF_ID  \n        INNER JOIN resource.tb_node_mst ND ON PT.NODE_ID = ND.NODE_ID \n        LEFT OUTER JOIN resource.tb_node_mst NM ON NM.NODE_ID = AL.ROOT_CAUSE_SYSNAMEA\n        LEFT JOIN nia.tb_sop SOP ON TC.TICKET_ID = SOP.TICKET_ID\n        WHERE TC.TICKET_TYPE IN ('NFTT', 'FTT', 'ATT2', 'NTT')\n            AND TC.PARENT_TICKET_ID IS NULL\n            AND TC.TICKET_GENERATION_TIME   >=   now() - INTERVAL '7' DAY\n        UNION ALL\n        SELECT \n            SAM.ALARMNO,\n            NULL TICKET_ID,\n            NULL CLUSTER_NO,\n            SAM.NODE_NUM,\n            SAM.NODE_NM,\n            SAM.ALARMLOC,\n            'SYSLOG' AS TICKET_TYPE,\n            NULL FAULT_TYPE,\n            SAM.ALARMTIME AS ALARMTIME,\n            NULL FAULT_TIME,\n            SAM.ALARMMSG,\n            NULL PORT,\n            SAM.ETC AS ALARMMSG_ORIGINAL,\n            CASE WHEN SAM.STATUS IN ('INIT', 'FIN', 'AUTO_FIN') THEN SAM.STATUS\n                ELSE '-'\n            END AS STATUS,\n            NULL TICKET_RCA_RESULT_DTL_CODE,\n            NULL TICKET_RCA_RESULT_CODE,\n            NULL TOTAL_RELATED_ALARM_CNT,\n            NULL ROOT_CAUSE_SYSNAMEA,\n            NULL ROOT_CAUSE_SYSNAMEZ,\n            NULL ROOT_CAUSE_PORTA,\n            NULL ROOT_CAUSE_PORTZ,\n            NULL ZERO1_ENTROPY,\n            NM.IP_ADDR AS IP_ADDR,\n            NULL AS AI_ACCURACY\n        FROM rca.tb_syslog_alarm_mst SAM\n        LEFT JOIN resource.tb_node_mst NM ON NM.NODE_ID = SAM.NODE_NM\n        WHERE ALARMTIME   >   now() - INTERVAL '48' HOUR\n    ) T\n    ORDER BY ALARMTIME DESC"
        ],
