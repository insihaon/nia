<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.nia.ip.sdn.linkage.mapper.nia.NiaE2eNodeMapper">

    <insert id="insertE2eNodeYd" parameterType="java.util.HashMap">
        <if test="e2eNodeVoList.size != 0">
            INSERT INTO IP_SDN.TB_E2E_NODE_YD
            (
                ID, SNODE_ID, RNODE_ID, USAGED
            )
            VALUES
            <foreach collection="e2eNodeVoList" item="item" separator=",">
            (
                #{item.id}, #{item.sNodeId}, #{item.rNodeId}, #{item.usaged}
            )
            </foreach>
        </if>
    </insert>

    <insert id="insertE2eNode">
        INSERT INTO IP_SDN.TB_E2E_NODE
        SELECT * FROM IP_SDN.TB_E2E_NODE_YD
    </insert>

    <delete id="deleteE2eNodeYd">
        TRUNCATE TABLE IP_SDN.TB_E2E_NODE_YD
    </delete>

    <delete id="deleteE2eNode">
        TRUNCATE TABLE IP_SDN.TB_E2E_NODE
    </delete>
</mapper>


