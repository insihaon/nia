* text=auto

# 유닉스 스타일 라인엔딩 유지
*.sh     text eol=lf
*.py     text eol=lf
*.conf   text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf

# 윈도우 스타일 라인엔딩
*.bat    text eol=crlf
*.cmd    text eol=crlf

# 바이너리 파일 (라인엔딩 변환 금지)
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.zip    binary
*.exe    binary
*.dll    binary