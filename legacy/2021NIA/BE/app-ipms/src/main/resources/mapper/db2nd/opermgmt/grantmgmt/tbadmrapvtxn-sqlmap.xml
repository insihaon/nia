		</trim>
	</sql>

	<sql id="List_Where_Clause">
		<trim prefix="WHERE" prefixOverrides="AND">
			1 = 1
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(nautAdmrSeq)">
				AND A.NAUT_ADMR_SEQ = #{nautAdmrSeq, jdbcType=BIGINT}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(ssvcLineTypeCd)">
				AND A.SSVC_LINE_TYPE_CD = #{ssvcLineTypeCd, jdbcType=CHAR}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(scentrId)">
