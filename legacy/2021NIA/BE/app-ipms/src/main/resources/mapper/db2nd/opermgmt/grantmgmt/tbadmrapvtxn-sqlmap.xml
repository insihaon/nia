		SELECT 
			COALESCE ( 
			  (SELECT DISTINCT SUSER_GRADE_CD FROM MST.TB_ADMR_APV_TXN
			 WHERE SUSER_ID = #{suserId, jdbcType=VARCHAR}
			 LIMIT 1 )
