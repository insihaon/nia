		, A.SADMR_USE_YN, A.SUSER_GRADE_CD, A.DCREATE_DT, A.SCREATE_ID
		, A.DMODIFY_DT, A.SMODIFY_ID

	</sql>
	
	<sql id="Append_Column_List">
		, B.SUSER_NM 
		, C.SSVC_LINE_TYPE_NM
		, D.SUSER_GRADE_NM
	</sql>
	
	<sql id="Append_Column_List_Alias">
		, A.SUSER_NM 
