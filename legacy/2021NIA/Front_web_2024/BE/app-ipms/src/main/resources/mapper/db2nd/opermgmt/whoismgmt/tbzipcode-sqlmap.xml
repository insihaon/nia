<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
	"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.kt.ipms.legacy.opermgmt.whoismgmt.dao.TbZipcodeDao">
	<resultMap id="tbZipcodeVoResult" type="com.kt.ipms.legacy.opermgmt.whoismgmt.vo.TbZipcodeVo">
		<result column="SZIPCODE" property="szipcode" jdbcType="VARCHAR" />
		<result column="ZIPCODE" property="zipcode" jdbcType="VARCHAR" />
		<result column="SERIALNO" property="serialno" jdbcType="VARCHAR" />
		<result column="PROVINCE" property="province" jdbcType="VARCHAR" />
		<result column="CITY" property="city" jdbcType="VARCHAR" />
		<result column="DONG" property="dong" jdbcType="VARCHAR" />
		<result column="RI" property="ri" jdbcType="VARCHAR" />
		<result column="DOSEO" property="doseo" jdbcType="VARCHAR" />
		<result column="SAN" property="san" jdbcType="VARCHAR" />
		<result column="START_NO" property="startNo" jdbcType="VARCHAR" />
		<result column="START_SUBNO" property="startSubno" jdbcType="VARCHAR" />
		<result column="END_NO" property="endNo" jdbcType="VARCHAR" />
		<result column="END_SUBNO" property="endSubno" jdbcType="VARCHAR" />
		<result column="DESTINATION" property="destination" jdbcType="VARCHAR" />
		<result column="DEST_SNO" property="destSno" jdbcType="VARCHAR" />
		<result column="DEST_ENO" property="destEno" jdbcType="VARCHAR" />
		<result column="UPDATE_DATE" property="updateDate" jdbcType="VARCHAR" />
		<result column="ADDRESS" property="address" jdbcType="VARCHAR" />
		<result column="EADDR" property="eaddr" jdbcType="VARCHAR" />
		
		<result column="RNUM" property="rowNo" jdbcType="NUMERIC" />
	</resultMap>
	<resultMap type="java.lang.String" id="provinceListResult">
		<result column="PROVINCE" jdbcType="VARCHAR" />
	</resultMap>
	<sql id="Base_Column_List">
		A.ZIPCODE, A.SERIALNO, A.PROVINCE, A.CITY, A.DONG,
		A.RI, A.DOSEO, A.SAN, A.START_NO, A.START_SUBNO, A.END_NO,
		A.END_SUBNO, A.DESTINATION, A.DEST_SNO, A.DEST_ENO,
		A.UPDATE_DATE, A.ADDRESS 
	</sql>
	<sql id="List_Where_Clause">
		<trim prefix="WHERE" prefixOverrides="AND">
			1 = 1
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(zipcode)">
				AND A.ZIPCODE = #{zipcode, jdbcType=VARCHAR}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(serialno)">
				AND A.SERIALNO = #{serialno, jdbcType=VARCHAR}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(province)">
				AND A.PROVINCE like '%' || #{province, jdbcType=VARCHAR} || '%'
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(city)">
				AND A.CITY like '%' || #{city, jdbcType=VARCHAR} || '%'
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(dong)">
				AND A.DONG like '%' || #{dong, jdbcType=VARCHAR} || '%'
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(ri)">
				AND A.RI = #{ri, jdbcType=VARCHAR}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(doseo)">
				AND A.DOSEO = #{doseo, jdbcType=VARCHAR}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(san)">
				AND A.SAN = #{san, jdbcType=VARCHAR}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(startNo)">
				AND A.START_NO = #{startNo, jdbcType=VARCHAR}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(startSubno)">
				AND A.START_SUBNO = #{startSubno, jdbcType=VARCHAR}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(endNo)">
				AND A.END_NO = #{endNo, jdbcType=VARCHAR}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(endSubno)">
				AND A.END_SUBNO = #{endSubno, jdbcType=VARCHAR}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(destination)">
				AND A.DESTINATION = #{destination, jdbcType=VARCHAR}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(destSno)">
				AND A.DEST_SNO = #{destSno, jdbcType=VARCHAR}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(destEno)">
				AND A.DEST_ENO = #{destEno, jdbcType=VARCHAR}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(updateDate)">
				AND A.UPDATE_DATE = #{updateDate, jdbcType=VARCHAR}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(address)">
				AND A.ADDRESS like '%' || #{address, jdbcType=VARCHAR} || '%'
			</if>
		</trim>
	</sql>
	<select id="selectListPageTbZipcode" parameterType="com.kt.ipms.legacy.opermgmt.whoismgmt.vo.TbZipcodeVo" resultMap="tbZipcodeVoResult">
		SELECT
			<include refid="Base_Column_List" />
			, BIF.UF_CONVERT_HAN_TO_ENG(A.PROVINCE || ' ' || A.CITY || 
			(CASE WHEN A.DONG IS NOT NULL THEN ' ' || A.DONG END) || 
			(CASE WHEN A.RI IS NOT NULL THEN ' ' || A.RI END) || 
			(CASE WHEN A.DOSEO IS NOT NULL THEN ' ' || A.DOSEO END) || 
			(CASE WHEN A.SAN IS NOT NULL THEN ' ' || A.SAN END) || 
			(CASE WHEN A.DESTINATION IS NOT NULL THEN ' ' || A.DESTINATION END),'Y') AS EADDR
			FROM BIF.TB_ZIPCODE A
			<include refid="List_Where_Clause" />
	</select>
	
	<select id="selectListProvince" resultMap="provinceListResult">
		SELECT PROVINCE, COUNT(ZIPCODE), COUNT(SERIALNO) FROM BIF.TB_ZIPCODE GROUP BY PROVINCE ORDER BY PROVINCE
	</select>
	
	<select id="selectEaddrDetail" resultType="java.lang.String" parameterType="java.lang.String">
		SELECT BIF.UF_CONVERT_HAN_TO_ENG(#{value},'N')
	</select>
</mapper>


