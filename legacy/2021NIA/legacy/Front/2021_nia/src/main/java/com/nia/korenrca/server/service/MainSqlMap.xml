<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.nia.korenrca.service.main">
    <!--@formatter:off-->

    <!--<editor-fold desc="[로그인]">-->
    <select id="SELECT_LOGIN" parameterType="hashmap" resultType="hashmap">
        SELECT A.ID AS LOGIN_ID,
                A.PW,
                A.NAME,
                A.LVL,
                A.LAST_LOGIN AS LAST_LOGIN,
                A.PHONE_NUMBER,
                A.email,
                A.AGENCY_NAME
        FROM nia.tb_user A
        <where>
            A.ID = #{LOGIN_ID}
        </where>
    </select>

    <!--<editor-fold desc="[사용자 추가]">-->
    <insert id ="INSERT_USER" parameterType="hashmap">
        INSERT
        INTO    nia.tb_user
        (
            id ,
            pw ,
            name ,
            lvl ,
            last_login,
            update_time,
            phone_number,
            email,
            agency_name
        )
        VALUES
        (
            #{LOGIN_ID},
            #{PW},
            #{NAME},
            #{LVL},
            NOW(),
            NOW(),
            #{USER_NUMBER},
            #{EMAIL},
            #{AGENCY_NAME}
        )
    </insert>
    <!--</editor-fold desc="[사용자 추가]">-->

    <select id="SELECT_FIND_USER_LIST" parameterType="hashmap" resultType="hashmap">
        SELECT A.ID,
        A.PW,
        A.NAME,
        A.LVL,
        A.LAST_LOGIN ,
        A.PHONE_NUMBER,
        A.email,
        A.AGENCY_NAME
        FROM nia.tb_user A
        <where>
            A.NAME = #{NAME} AND
            A.PHONE_NUMBER = #{USER_NUMBER}
            <if test="LOGIN_ID != null">
                AND A.ID = #{LOGIN_ID}
            </if>
            <if test="EMAIL != null">
                AND A.EMAIL= #{EMAIL}
            </if>
        </where>
    </select>

    <!--<editor-fold desc="[사용자 삭제]">-->
    <delete id="DELETE_USER" parameterType="hashmap" >
        DELETE FROM
            nia.tb_user
        WHERE  ID = #{LOGIN_ID}
    </delete>
    <!--</editor-fold desc="[사용자 삭제]">-->

    <!-- 업데이트 마지막 로그인 -->
    <update id="UPDATE_LAST_LOGIN" parameterType="hashmap">
        UPDATE nia.tb_user
        SET LAST_LOGIN = NOW()
        <where>
            ID = #{LOGIN_ID}
        </where>
    </update>

    <update id ="UPDATE_USER_DATA" parameterType="hashmap">
        UPDATE nia.tb_user
        <set>
            <if test="PW != null">
                PW = #{PW},
            </if>
            <if test="NAME != null">
                NAME = #{NAME},
            </if>
            <if test="USER_NUMBER != null">
                PHONE_NUMBER = #{USER_NUMBER},
            </if>
            <if test="EMAIL != null">
                EMAIL = #{EMAIL},
            </if>
            <if test="AGENCY_NAME != null">
                AGENCY_NAME = #{AGENCY_NAME},
            </if>
            UPDATE_TIME = NOW(),
            LAST_LOGIN = NOW()
        </set>
        WHERE  ID = #{LOGIN_ID}
    </update>

    <!--@formatter:on-->
</mapper>
