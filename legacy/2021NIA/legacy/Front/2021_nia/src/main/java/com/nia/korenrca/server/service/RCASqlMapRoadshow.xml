<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.nia.korenrca.service.rca">
<!-- @formatter:off -->
     <select id="SELECT_DEVALMCURRENT_IP_LIST" parameterType="hashmap" resultType="hashmap">
        SELECT *
        FROM roadshow.cur_devalmcurrent_ip_count
        ORDER BY receivetime DESC
        LIMIT 30
    </select>
    <select id="SELECT_DEVALMCURRENT_LTE_LIST" parameterType="hashmap" resultType="hashmap">
        SELECT *
        FROM roadshow.cur_devalmcurrent_lte_count
        ORDER BY receivetime
        LIMIT 30
    </select>
    <select id="SELECT_DEVALMCURRENT_TOPAS_LIST" parameterType="hashmap" resultType="hashmap">
        SELECT *
        FROM roadshow.cur_devalmcurrent_topas_count
        ORDER BY receivetime
        LIMIT 30
    </select>

<!-- @formatter:on -->
</mapper>


