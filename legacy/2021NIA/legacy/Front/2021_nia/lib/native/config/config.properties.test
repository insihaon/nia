[rca]
profile.name=dev,test
http.server.port=8080
https.server.port=8081
socket.server.port=8084
socket.server.start=true
proxy.server.start=true
proxy.server.test=false

# LDAP
auth.use=false
ldap.use=false
ldap.ssl=false
ldap.port=389
ldap.host=10.217.40.53
ldap.baseDN=OU=Employee,DC=ldap,DC=ktlab,DC=dev
ldap.connID=nmsai_ldapdevuser
ldap.connPW=NMS@i_Ld@pDevUser!

# HTTPS KeyStore
keystore.file.path=config/rca.jks
keystore.password=rca1234

web.path=app/websrc
download.path=download
web.compression.supported=true

db.url=jdbc:postgresql://10.81.208.122:5433/ktrca
db.driver=org.postgresql.Driver
db.poolmax=1000
db.username=rcadb
db.password=rcadb12#$

# rabbitmq
rabbitmq.host=10.81.208.123
rabbitmq.port=5675
rabbitmq.user=rcaadmin
rabbitmq.password=rcaadmin12#$
rabbitmq.key.receive.exchange: rca.exchangeEngineToUiDirectly
rabbitmq.key.receive.queueName: rca.EngineToUiIndexDirectly
rabbitmq.key.receive.routingKey: EngineToUiIndexDirectly
rabbitmq.key.send.exchange: rca.exchangeUiToEngineDirectly
rabbitmq.key.send.queueName: rca.UiToEngineIndexDirectly
rabbitmq.key.send.routingKey: UiToEngineIndexDirectly

