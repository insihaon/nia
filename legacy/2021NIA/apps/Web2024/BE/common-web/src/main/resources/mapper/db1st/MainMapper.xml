<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.codej.web.mapper.db1st.MainMapper">
    <sql id="GET_LIMIT">
        <if test="TO_LOAD != null and TO_LIMIT != null">
            LIMIT #{TO_LOAD}, #{TO_LIMIT}
        </if>
    </sql>

    <select id="SELECT_LOGIN_ID" parameterType="hashmap" resultType="com.codej.base.dto.model.ResultMap">
        SELECT COUNT(*) COUNT
        FROM t_login_map
        <where>
            I_ID = #{I_ID}
        </where>
    </select>

    <update id="USER_NEW_PW" parameterType="hashmap">
        UPDATE t_login_map
        <set>
            S_PW = #{password},
            D_MOD_DT = NOW()
        </set>
        WHERE I_ID = #{I_ID}
    </update>

</mapper>
