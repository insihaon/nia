<!-- 예지보전 토폴로지 노드 조회 -->
<select id="SELECT_PMM_TOPOLOGY_LIST" parameterType="hashmap" resultType="hashmap">
    WITH base AS (
        SELECT
            oph.*,
            SPLIT_PART(oph.trunk_name, '--', 1) AS from_node,
            SPLIT_PART(oph.trunk_name, '--', 2) AS to_node
        FROM mba.tb_roadm_optical_performance_hist oph
        WHERE oph.ocrtime <![CDATA[ > ]]> RCA.FC_GET_MINUS_DAY(1)
        AND oph.trunk_name = #{TRUNK_NAME}
        AND oph.direction  = #{DIRECTION}
    ),
    max_hist AS (
        SELECT
            trunk_name,
            direction,
            sysname,
            MAX(ocrtime) AS ocrtime
        FROM base
        WHERE sysname IN (from_node, to_node)
        GROUP BY trunk_name, direction, sysname
    ),
    snap AS (
        SELECT b.*
        FROM base b
        JOIN max_hist m
        ON b.trunk_name = m.trunk_name
        AND b.direction  = m.direction
        AND b.sysname    = m.sysname
        AND b.ocrtime    = m.ocrtime
    )
    SELECT
        TO_CHAR(MAX(s.ocrtime), 'YYYY-MM-DD HH24:MI:SS') AS OCRTIME,
        s.trunk_name,
        s.direction,
        s.sysname,
        COALESCE(MAX(s.routenum), 0) AS routenum,
        CONCAT(
            ROUND(MAX(CASE WHEN s.in_out = 'IN'  THEN s.value_max END), 1),
            '/',
            ROUND(MAX(CASE WHEN s.in_out = 'OUT' THEN s.value_max END), 1)
        ) AS RX_TX
    FROM snap s
    LEFT JOIN mba.tb_roadm_trunk_topology rt
    ON rt.trunk_name = s.trunk_name
    GROUP BY
        s.trunk_name,
        s.direction,
        s.sysname
    ORDER BY
        COALESCE(MAX(s.routenum), MAX(rt.routenum), 999999)
    <!-- WITH MAX_HIST AS (
        SELECT
            MAX(END_TIME) end_time
            , SPLIT_PART(MONITORED_OBJECT, '-', 1) AS NESCODE
        FROM mba.tb_roadm_optical_performance_hist oph
        WHERE oph.END_TIME  > RCA.FC_GET_MINUS_DAY(1)
        GROUP BY NESCODE
    )
    SELECT 
        TO_CHAR(END_TIME, 'YYYY-MM-DD HH24:MI:SS') AS END_TIME
        , RT.NAME_CODE
        , T.TRUNK_NAME
        , RT.SYSNAME
        , DIRECTION
        , T.NESCODE
        , CONCAT(ROUND(MAX(T.IN_VALUE_MAX), 1), '/', ROUND(MAX(T.OUT_VALUE_MAX), 1)) AS RX_TX
        , CONCAT(ROUND(MAX(T.SPAN_LOSS), 1), '/', ROUND(MAX(T.NODE_GAIN), 1)) AS SPAN_GAIN
        , COALESCE(MAX(T.NODE_TOTAL_DEVIATION), 0) AS NODE_TOTAL_DEVIATION
        , RT.TRANSCIRCUITSEQ
        , RT.TRANSCIRCUITNAME
        , RT.EQUIP_TYPE
        , RT.EQUIP_TYPE
        , RT.OFFICESCODE
        , RT.OFFICENAME
        , RT.ROUTENUM
    FROM (
        SELECT
            C_OP.MONITORED_OBJECT
            , C_OP.END_TIME
            , C_OP.NAME_CODE
            , CASE WHEN TN.TRUNK_NAME IS NULL THEN TR.TRUNK_NAME 
                ELSE TN.TRUNK_NAME
            END TRUNK_NAME
            , C_OP.DIRECTION
            , C_OP.NESCODE
            , C_OP.IN_OUT
            , CASE WHEN C_OP.IN_OUT = 'IN' THEN VALUE_MAX
                ELSE NULL END IN_VALUE_MAX
            , CASE WHEN C_OP.IN_OUT = 'OUT' THEN VALUE_MAX
                ELSE NULL END OUT_VALUE_MAX
            , C_OP.SUB_SHELF
            , C_OP.VALUE_MAX
            , C_OP.SPAN_LOSS
            , C_OP.NODE_GAIN
            , C_OP.NODE_TOTAL_DEVIATION
    FROM (
        SELECT 
            MONITORED_OBJECT
            , max_hist.END_TIME
            , NAME_CODE
            , DIRECTION
            , SPLIT_PART(MONITORED_OBJECT, '-', 1) AS NESCODE
            , REGEXP_REPLACE(SPLIT_PART(MONITORED_OBJECT, '-', 4), '[^A-ZA-Z]', '', 'g') AS IN_OUT
            , LPAD(SPLIT_PART(SPLIT_PART(MONITORED_OBJECT, '/', 4), '=', 2), 2, '0') AS SUB_SHELF
            , VALUE_MAX
            , SPAN_LOSS
            , NODE_GAIN
            , NODE_TOTAL_DEVIATION
            FROM MAX_HIST
            LEFT JOIN mba.tb_roadm_optical_performance_hist HIST ON MAX_HIST.end_time = HIST.end_time 
                AND MAX_HIST.nescode = SPLIT_PART(HIST.MONITORED_OBJECT, '-', 1)
        ) c_op
        LEFT OUTER JOIN (
            SELECT trunk_name, from_nescode, substring(from_rssup, 3, 2) AS from_sub_shelf, to_nescode, substring(to_rssup, 3, 2) AS to_sub_shelf
            FROM topas.inv_fm_roadm_trunk_yd
        ) tn ON (tn.from_nescode = c_op.nescode AND tn.from_sub_shelf = c_op.sub_shelf ) OR (tn.to_nescode = c_op.nescode AND tn.to_sub_shelf = c_op.sub_shelf)
        LEFT OUTER JOIN (
            SELECT DISTINCT trunk_name, repeater_nescode
            FROM topas.inv_fm_roadm_trunk_repeater_yd
        ) tr ON tr.repeater_nescode = c_op.nescode
    ) T
    LEFT OUTER JOIN mba.tb_roadm_trunk_topology rt ON rt.trunk_name = T.trunk_name AND rt.nescode = T.nescode
    WHERE rt.trunk_name =#{TRUNK_NAME} AND T.direction = #{DIRECTION}
    GROUP BY end_time, rt.name_code, T.trunk_name, rt.sysname, direction, T.nescode, sub_shelf, rt.transcircuitseq
        , rt.transcircuitname, rt.equip_type, rt.equip_type, rt.officescode, rt.officename, rt.routenum
    ORDER BY rt.routenum -->
</select>

