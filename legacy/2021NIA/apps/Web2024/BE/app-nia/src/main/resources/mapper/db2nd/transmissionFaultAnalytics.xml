<!--  예지보전 전표 운용자 검토 의견 upsert -->
<update id="UPDATE_MBA_PREDICTIVE_REVIEW" parameterType="hashmap">
    WITH UPSERT AS ( UPDATE mba.tb_roadm_predictive_handling
    <set>
        <if test="handling_time != null">
        HANDLING_TIME = #{handling_time}::TIMESTAMP
        </if>
        <if test="handling_user != null">
        , HANDLING_USER = #{handling_user}
        </if>
        <if test="handling_dept != null">
        ,  HANDLING_DEPT = #{handling_dept}
        </if>
        <if test="handling_agency != null">
        ,  HANDLING_AGENCY = #{handling_agency}
        </if>
        <if test="handling_content != null">
        , HANDLING_CONTENT = #{handling_content}
        </if>
    </set>
    WHERE SEQNUM = #{seqnum} RETURNING * )
    INSERT INTO  
    mba.tb_roadm_predictive_handling (
        TICKETNO
        , ISSUE_DATE
        , INSERT_TIME
        <if test="handling_time != null">
        , HANDLING_TIME
        </if>
        <if test="handling_user != null">
        , HANDLING_USER
        </if>
        <if test="handling_dept != null">
        , HANDLING_DEPT
        </if>
        <if test="handling_agency != null">
        , HANDLING_AGENCY
        </if>
        <if test="handling_content != null">
        , HANDLING_CONTENT
        </if>
        )
            SELECT 
        #{ticketno}::VARCHAR
        , #{issue_date}::DATE
        , now()
        <if test="handling_time != null">
            , #{handling_time}::TIMESTAMP
        </if>
        <if test="handling_user != null">
            , #{handling_user}
        </if>
        <if test="handling_dept != null">
            , #{handling_dept}
        </if>
        <if test="handling_agency != null">
            , #{handling_agency}
        </if>
        <if test="handling_content != null">
            , #{handling_content}
        </if>
            WHERE NOT EXISTS(SELECT 1 FROM UPSERT)
</update>

