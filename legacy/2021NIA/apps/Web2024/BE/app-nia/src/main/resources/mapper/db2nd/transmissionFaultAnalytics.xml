<select id="SELECT_TICKET_PMM_LIST" parameterType="hashmap" resultType="hashmap">
    SELECT
    ticketno
    , issue_date
    , clear_date
    , reason
    <!-- , pmt.trunk_name -->
    <!-- , (
        SELECT DISTINCT im.metype 
        FROM topas.inv_managedelement im
        WHERE target_idx_zero = im.sysname
    ) AS metype -->
    , direction
    , target_sysname
    , node_total_deviation
    <!-- , roadm_cnt -->
    <!-- , opinion_cnt -->
    , is_check_modal
    <!-- , last_handling_time -->
    FROM (
        SELECT 
            ticketno
            , issue_date
            , clear_date
            , reason
            , pmt.trunk_name
            , pmt.direction
            , target_sysname
            , SPLIT_PART(pmt.target_sysname, ',', 1) AS target_idx_zero
            , MIN(rop.node_total_deviation) AS node_total_deviation
            , COALESCE((
                SELECT count(*)
                FROM mba.tb_roadm_trunk_topology
                WHERE trunk_name = pmt.trunk_name
            ), 0) AS roadm_cnt
            <!-- , (
                SELECT COUNT(*) FROM mba.tb_roadm_predictive_handling rph 
                WHERE rph.ticketno = pmt.ticketno AND rph.issue_date = pmt.issue_date AND delete_yn = 'N'
            ) AS opinion_cnt -->
            <!-- , (
                SELECT ARRAY_AGG(seqnum)
                FROM mba.tb_roadm_predictive_handling rph
                WHERE rph.ticketno = pmt.ticketno AND rph.issue_date = pmt.issue_date AND delete_yn = 'N' AND rph.handling_time  <![CDATA[ > ]]> current_date - CAST(7 || 'day' AS INTERVAL)
            ) AS new_list -->
            , FALSE AS is_check_modal
            <!-- , (
                SELECT TO_CHAR(MAX(rph.handling_time), 'YYYY-MM-DD HH24:MI:SS') FROM mba.tb_roadm_predictive_handling rph 
                WHERE rph.ticketno = pmt.ticketno AND rph.issue_date = pmt.issue_date AND delete_yn = 'N'
            ) AS last_handling_time -->
        FROM mba.tb_roadm_predictive_maintenance_ticket pmt
        LEFT JOIN mba.tb_roadm_optical_performance_daily rop 
            ON rop.trunk_name = pmt.trunk_name
            AND rop.direction = pmt.direction
            AND rop.sysname = ANY(STRING_TO_ARRAY(pmt.target_sysname, ','))
            AND rop.collection_date = pmt.issue_date
            <!-- AND rop.monitored_object like '%IN%' -->
        GROUP BY pmt.ticketno, pmt.issue_date, pmt.clear_date, pmt.reason,  pmt.trunk_name, pmt.direction, pmt.target_sysname
    ) pmt
    ORDER BY issue_date DESC 
