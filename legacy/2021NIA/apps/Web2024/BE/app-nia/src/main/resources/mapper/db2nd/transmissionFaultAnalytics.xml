<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.codej.nia.mapper.db2nd.transmissionFaultAnalytics">

<sql id="SUB_TICKET">
    <bind name="IS_MONITORING" value="(LIMIT == null and OFFSET == null)"/>    <!-- 모니터링 -->
    <bind name="IS_HISTORY" value="(LIMIT != null or OFFSET != null)"/>        <!-- 전표현황 -->

    <if test="MAX_DAYS != null">
        <bind name="TICKET_DAYS" value="MAX_DAYS"/>
    </if>
    <if test="MAX_DAYS == null">
        <bind name="TICKET_DAYS" value="14"/>
    </if>
    WITH sub_ticket AS
        (
            SELECT T.*
            FROM rca.tb_rca_ticket_current T
            <if test="SYS != null or ORG != null"> <!-- 전표현황 > sysname/org 검색시 -->
                LEFT OUTER JOIN (
                    SELECT SUB_AL3.* , ROW_NUMBER() OVER (PARTITION BY SUB_AL3.TICKET_ID ORDER BY SUB_AL3.EQUIP_TYPE_ORDER_NUM<!-- , SUB_AL3.TRANSCIRCUITSEQ DESC -->, TICKET_AL_ID DESC) AS ORDER_NUM
                    FROM (
                        SELECT SUB_AL2.*,
                            CASE WHEN ROOT_CAUSE_SYSNAMEA LIKE '%ROADM%' OR ROOT_CAUSE_SYSNAMEZ LIKE '%ROADM%' THEN 1
                                    WHEN ROOT_CAUSE_SYSNAMEA LIKE '%POTN%' OR ROOT_CAUSE_SYSNAMEZ LIKE '%POTN%' THEN 2
                                    WHEN ROOT_CAUSE_SYSNAMEA LIKE '%MSPP%' OR ROOT_CAUSE_SYSNAMEZ LIKE '%MSPP%' THEN 3
                                    WHEN ROOT_CAUSE_SYSNAMEA LIKE '%PTS%' OR ROOT_CAUSE_SYSNAMEZ LIKE '%PTS%' THEN 4
                                    ELSE 5
                            END AS EQUIP_TYPE_ORDER_NUM
                        FROM rca.tb_rca_ticket_al_current SUB_AL2
                        <!-- [tb_rca_ticket_al_current] full scan 방지를 위한 조건 -->
                        <!-- <where>
                            <trim prefix="(" prefixOverrides="AND|OR" suffix=")" suffixOverrides="">
                                <if test="SYS != null">
                                    AND (SUB_AL2.ROOT_CAUSE_SYSNAMEA::text LIKE '%' || #{SYS} || '%' OR SUB_AL2.ROOT_CAUSE_SYSNAMEZ::text LIKE '%' || #{SYS} || '%')
                                </if>
                                <if test="ORG != null">
                                    AND (SUB_AL2.ROOT_CAUSE_ORGA_1::text LIKE '%' || #{ORG} || '%' OR SUB_AL2.ROOT_CAUSE_ORGZ_1::text LIKE '%' || #{ORG} || '%')
                                </if>
                            </trim>
                        </where> -->
                    ) SUB_AL3
                ) AL ON T.TICKET_ID = AL.TICKET_ID AND AL.ORDER_NUM = 1
            </if>
            <!-- 전표현황 > location 케이블 검색시 -->
            <!-- <if test="LOC != null"> 
                LEFT OUTER JOIN (
                    SELECT SUB_OCA.*
                    FROM (
                        SELECT DISTINCT ON (A.TICKET_ID)
                            A.OCASEQ AS OCASEQ,
                            A.TRANSCIRCUITSEQ AS TRANSCIRCUITSEQ,
                            A.TICKET_ID,
                            CL.MAX_RATIO AS MAX_RATIO,
                            R2.ORDER_NUM AS ORDER_NUM
                        FROM rca.tb_rca_ticket_ocaseq_current A
                            INNER JOIN rca.tb_ocaroute R2 ON A.OCASEQ = R2.OCASEQ AND A.TRANSCIRCUITSEQ = R2.TRANSCIRCUITSEQ
                            LEFT OUTER JOIN (
                                SELECT
                                    B.OCASEQ,
                                    B.MAX_RATIO
                                from rca.tb_oca_cl_count B
                                GROUP BY   B.OCASEQ,B.MAX_RATIO) CL ON A.OCASEQ = CL.OCASEQ
                            <where>
                            <trim prefix="(" prefixOverrides="AND|OR" suffix=")" suffixOverrides="">
                                <if test="IS_MONITORING == true"> 
                                    AND A.INSERT_TIME <![CDATA[ >= ]]> RCA.FC_GET_MINUS_DAY(#{TICKET_DAYS} + 3)
                                </if>
                            </trim>
                            </where>
                        ORDER BY  A.TICKET_ID, CL.MAX_RATIO DESC, R2.ORDER_NUM ASC, A.OCASEQ, A.TRANSCIRCUITSEQ
                    ) SUB_OCA ORDER BY SUB_OCA.OCASEQ
                ) OCA ON T.TICKET_ID = OCA.TICKET_ID
                LEFT OUTER JOIN (
                    SELECT *
                        , row_number() OVER (PARTITION BY OCASEQ ORDER BY TRANSCIRCUITSEQ DESC) AS TC_ORDER_NUM
                    FROM rca.tb_ocaroute
                ) R ON OCA.OCASEQ = R.OCASEQ AND R.TC_ORDER_NUM = 1
                LEFT OUTER JOIN topas.tb_oca1 OCA1 ON R.OCASEQ = OCA1.OCASEQ
                LEFT OUTER JOIN aib_inst.tb_instlocation LOC_A ON R.INSTLOCATIONA = LOC_A.INSTLOCATION
                LEFT OUTER JOIN aib_inst.tb_instlocation LOC_Z ON R.INSTLOCATIONZ = LOC_Z.INSTLOCATION
            </if> -->
            WHERE (
                T.PARENT_TICKET_ID IS NULL
                <if test="IS_MONITORING == true"> <!-- 모니터링 -->
                    AND T.TICKET_TYPE != 'CIT2'
                    <!-- AND T.TICKET_GENERATION_TIME <![CDATA[ >= ]]> RCA.FC_GET_MINUS_DAY(#{TICKET_DAYS}) -->
                </if>
                <if test="TICKET_ID != null">
                    AND T.TICKET_ID = #{TICKET_ID}::VARCHAR
                </if>
                <if test="TICKET_ID_LIKE != null">
                    AND T.TICKET_ID LIKE '%' || #{TICKET_ID_LIKE}::VARCHAR || '%'
                </if>
                <if test="LAST_TICKET_ID != null">
                    AND T.TICKET_ID::int <![CDATA[ > ]]> #{LAST_TICKET_ID}::int
                </if>
                <if test="ID != null">
                    AND (T.TICKET_ID::text LIKE '%' || #{ID}::VARCHAR || '%')
                </if>
                <if test="CIT2 != null">
                    AND T.TICKET_TYPE = 'CIT2'
                    AND (T.TICKET_ID::text LIKE '%' || #{CIT2}::VARCHAR || '%')
                </if>
                <if test="IS_MBA != null">
                    AND T.ROOT_CAUSE_TYPE = 'MomentaryBreakoff'
                </if>
                <if test="FROM != null">
                    AND T.TICKET_GENERATION_TIME <![CDATA[ >= ]]> #{FROM}::TIMESTAMP
                </if>
                <if test="TO != null">
                    AND T.TICKET_GENERATION_TIME <![CDATA[ <= ]]> #{TO}::TIMESTAMP
                </if>
                <if test="SYS != null">
                    AND (AL.ROOT_CAUSE_SYSNAMEA::text LIKE '%' || #{SYS} || '%' OR AL.ROOT_CAUSE_SYSNAMEZ::text LIKE '%' || #{SYS} || '%')
                </if>
                <!-- <if test="ORG != null">
                    AND (AL.ROOT_CAUSE_ORGA_1::text LIKE '%' || #{ORG} || '%' OR AL.ROOT_CAUSE_ORGZ_1::text LIKE '%' || #{ORG} || '%')
                </if> -->
                <!-- <if test="LOC != null">
                    AND (LOC_A.LOCDESCRIPTION::text LIKE '%' || #{LOC} || '%' OR LOC_Z.LOCDESCRIPTION::text LIKE '%' || #{LOC} || '%')
                </if> -->
            )
            <if test="IS_HISTORY == true">
                ORDER BY T.TICKET_UPDATE_TIME DESC, T.TICKET_GENERATION_TIME DESC, T.TICKET_ID::int DESC
            </if>
            <if test="OFFSET != null"> <!-- 전표현황 -->
                OFFSET #{OFFSET} LIMIT 100
            </if>
            <if test="OFFSET == null and LIMIT != null"> <!-- 전표현황 > 엑셀출력 -->
                LIMIT #{LIMIT}
            </if>
        )
        , sub_min_day AS (
            SELECT (MIN(TICKET_GENERATION_TIME)::DATE - 3)::TIMESTAMP WITH TIME ZONE
            FROM sub_ticket
        )
        , sub_max_day AS (
            SELECT (MAX(TICKET_GENERATION_TIME)::DATE + 3)::TIMESTAMP WITH TIME ZONE
            FROM sub_ticket
        )
        , sub_al AS (
            SELECT AL.*
            FROM rca.tb_rca_ticket_al_current AL
            INNER JOIN (SELECT ticket_id FROM sub_ticket) SUB_T ON SUB_T.ticket_id = AL.ticket_id
            WHERE AL.insert_time <![CDATA[ >= ]]> <include refid="SUB_TICKET_MIN_DAY"/>
            AND AL.insert_time <![CDATA[ <= ]]> <include refid="SUB_TICKET_MAX_DAY"/>
        )
        <!-- , sub_ai AS
        (
            SELECT AI.*
            FROM (
                SELECT ticket_id, max(reanalysis_time) AS reanalysis_time
                FROM rca.tb_rca_user_check_ai_result
                WHERE
                    reanalysis_time <![CDATA[ >= ]]> <include refid="SUB_TICKET_MIN_DAY"/>
                    AND reanalysis_time <![CDATA[ <= ]]> <include refid="SUB_TICKET_MAX_DAY"/>
                GROUP BY ticket_id
            ) AI_TIME
            LEFT OUTER JOIN (
                SELECT *
                FROM rca.tb_rca_user_check_ai_result
                WHERE
                    reanalysis_time <![CDATA[ >= ]]> <include refid="SUB_TICKET_MIN_DAY"/>
                    AND reanalysis_time <![CDATA[ <= ]]> <include refid="SUB_TICKET_MAX_DAY"/>
            ) AI ON AI.reanalysis_time = AI_TIME.reanalysis_time AND AI.ticket_id = AI_TIME.ticket_id
        ) -->
</sql>

<!-- 메인 TICKET_SELECT -->
<sql id="SUB_TICKET_MIN_DAY">
    <if test="IS_MONITORING == true">
        RCA.FC_GET_MINUS_DAY(#{TICKET_DAYS} + 3)
    </if>
    <if test="IS_HISTORY == true">
        (SELECT * FROM sub_min_day)
    </if>
</sql>
<sql id="SUB_TICKET_MAX_DAY">
    <if test="IS_MONITORING == true">
        RCA.FC_GET_MINUS_DAY(-3)
    </if>
    <if test="IS_HISTORY == true">
        (SELECT * FROM sub_max_day)
    </if>
</sql>

<select id="SELECT_TICKET_CUR_LIST" parameterType="hashmap" resultType="hashmap">
    <include refid="SUB_TICKET"/>
    SELECT T.TICKET_ID                                               AS TICKET_ID
        , T.PARENT_TICKET_ID                                        AS PARENT_TICKET_ID
        , T.TICKET_TYPE                                             AS TICKET_TYPE
        , T.CLUSTER_NO                                              AS CLUSTER_NO
        , TO_CHAR(T.TICKET_GENERATION_TIME, 'YYYY-MM-DD HH24:MI:SS') AS GENERATION_TIME -- TICKET TIME
        , TO_CHAR(T.FAULT_TIME, 'YYYY-MM-DD HH24:MI:SS')             AS FAULT_TIME      -- OCCURRED TIME
        , T.ROOT_CAUSE_TYPE                                         AS ROOT_CAUSE_TYPE
        , T.ROOT_CAUSE_CODE                                         AS ROOT_CAUSE_CODE
        , T.STATUS                                                  AS STATUS
        <!-- , T.TICKET_FM_NONFM                                         AS TICKET_FM_NONFM -->
        <!-- , T.TICKET_RCA_TYPE                                         AS TICKET_RCA_TYPE -->
        , T.TICKET_RCA_RESULT_CODE                                  AS TICKET_RCA_RESULT_CODE
        , T.TICKET_RCA_RESULT_ORIG_DTL_CODE                         AS TICKET_RCA_RESULT_ORIG_DTL_CODE
        , T.TICKET_RCA_RESULT_DTL_CODE                              AS TICKET_RCA_RESULT_DTL_CODE
        <!-- , T.NATURE_RESTORATION                                      AS NATURE_RESTORATION -->
        <!-- , T.WORK_FAIL                                               AS WORK_FAIL -->
        , TO_CHAR(COALESCE (T.TICKET_UPDATE_TIME, T.TICKET_GENERATION_TIME), 'YYYY-MM-DD HH24:MI:SS') AS UPDATE_TIME
        , T.ROOT_CAUSE_DOMAIN                                       AS ROOT_CAUSE_DOMAIN
        <!-- , T.DERIVATION                                              AS DERIVATION -->
        <!-- , T.TT_NULL                                                 AS TT_NULL -->
        <!-- , T.CIRCUIT_YN                                              AS CIRCUIT_YN -->
        , T.DIRECTION                                               AS DIRECTION
        , T.ROW_SIGNAL_LINE_CNT                                     AS ROW_SIGNAL_LINE_CNT
        , T.TRUNK_NAME                                              AS TRUNK_NAME
        <!-- , (
            SELECT DISTINCT IM.METYPE 
            FROM topas.inv_managedelement IM
            WHERE MBA_AL.ROOT_CAUSE_SYSNAMEA = IM.SYSNAME
        ) AS METYPE -->
        <!-- , T.AI_RESULT                                               AS AI_RESULT -->
        , AL.TICKET_AL_ID                                           AS TICKET_AL_ID
        , AL.ROOT_CAUSE_SYSNAMEA                                    AS ROOT_CAUSE_SYSNAMEA
        , AL.ROOT_CAUSE_PORTA                                       AS ROOT_CAUSE_PORTA
        <!-- , AL.ROOT_CAUSE_OFFICEA                                     AS ROOT_CAUSE_OFFICEA -->
        <!-- , AL.ROOT_CAUSE_METYPEA                                     AS ROOT_CAUSE_METYPEA -->
        , AL.ROOT_CAUSE_EQUIP_TYPEA                                 AS ROOT_CAUSE_EQUIP_TYPEA
        <!-- , AL.ROOT_CAUSE_ORGA_1                                      AS ROOT_CAUSE_ORGA_1 -->
        <!-- , AL.ROOT_CAUSE_ORGA_2                                      AS ROOT_CAUSE_ORGA_2 -->
        <!-- , AL.ROOT_CAUSE_ORGA_3                                      AS ROOT_CAUSE_ORGA_3 -->
        <!-- , AL.ROOT_CAUSE_ORGA_4                                      AS ROOT_CAUSE_ORGA_4 -->
        <!-- , AL.ROOT_CAUSE_SYSNAMEZ                                    AS ROOT_CAUSE_SYSNAMEZ -->
        , AL.ROOT_CAUSE_PORTZ                                       AS ROOT_CAUSE_PORTZ
        <!-- , AL.ROOT_CAUSE_OFFICEZ                                     AS ROOT_CAUSE_OFFICEZ -->
        <!-- , AL.ROOT_CAUSE_METYPEZ                                     AS ROOT_CAUSE_METYPEZ -->
        , AL.ROOT_CAUSE_EQUIP_TYPEZ                                 AS ROOT_CAUSE_EQUIP_TYPEZ
        <!-- , AL.ROOT_CAUSE_ORGZ_1                                      AS ROOT_CAUSE_ORGZ_1 -->
        <!-- , AL.ROOT_CAUSE_ORGZ_2                                      AS ROOT_CAUSE_ORGZ_2 -->
        <!-- , AL.ROOT_CAUSE_ORGZ_3                                      AS ROOT_CAUSE_ORGZ_3 -->
        <!-- , AL.ROOT_CAUSE_ORGZ_4                                      AS ROOT_CAUSE_ORGZ_4 -->
        <!-- , AL.ROOT_CAUSE_SYS_LOCATION       s                         AS ROOT_CAUSE_SYS_LOCATION -->
        , MBA_AL.ROOT_CAUSE_SYSNAMEA                                AS MBA_SYSNAMEA
        , MBA_AL.ROOT_CAUSE_SYSNAMEZ                                AS MBA_SYSNAMEZ
        <!-- , R.OCASEQ                                                  AS OCASEQ -->
        <!-- , R.TRANSCIRCUITSEQ                                         AS TRANSCIRCUITSEQ -->
        <!-- , OCA1.OCANAME                                              AS OCANAME -->
        <!-- , LOC_A.LOCDESCRIPTION                                      AS LOCDESCRIPTIONA -->
        <!-- , LOC_Z.LOCDESCRIPTION                                      AS LOCDESCRIPTIONZ -->
        <!-- , OFF_A.OFFICENAME                                          AS OFFICENAMEA -->
        <!-- , OFF_Z.OFFICENAME                                          AS OFFICENAMEZ -->
        , STATUS.RCA_ACCURACY                                       AS RCA_ACCURACY
        , STATUS.HANDLING_CONTENT                                   AS HANDLING_CONTENT
        , STATUS.HANDLING_FIN_CONTENT                               AS HANDLING_FIN_CONTENT
        , TO_CHAR(STATUS.HANDLING_TIME, 'YYYY-MM-DD HH24:MI:SS')                                      AS HANDLING_TIME
        , STATUS.HANDLING_USER                                      AS HANDLING_USER
        , STATUS.HANDLING_DEPT                                      AS HANDLING_DEPT
        , STATUS.HANDLING_AGENCY                                    AS HANDLING_AGENCY
        , TO_CHAR(STATUS.HANDLING_ACK_TIME, 'YYYY-MM-DD HH24:MI:SS')       AS HANDLING_ACK_TIME
        , STATUS.HANDLING_FIN_USER                                  AS HANDLING_FIN_USER
        , STATUS.HANDLING_FIN_DEPT                                  AS HANDLING_FIN_DEPT
        , STATUS.HANDLING_FIN_AGENCY                                AS HANDLING_FIN_AGENCY
        <!-- , STATUS.FAULT_TYPE                                         AS FAULT_TYPE -->
        , (
                SELECT  CURRENT_TIMESTAMP - T.TICKET_GENERATION_TIME <![CDATA[ <= ]]> '5 minute'
        ) AS IS_NEW_TICKET
        , COALESCE(CNT.TOTAL_ALARM_COUNT, 0)                        AS TOTAL_ALARM_COUNT
        , AL2.ROOT_CAUSE_CHECKA                                     AS ROOT_CAUSE_CHECKA
        , AL2.ROOT_CAUSE_CHECKZ                                     AS ROOT_CAUSE_CHECKZ
        , COALESCE(CNT.RELATED_ALARM_COUNT, 0)                      AS TOTAL_RELATED_ALARM_COUNT
        , CNT.CHILD_COUNT                                           AS CHILD_COUNT
        <!-- , COALESCE(CODE.NAME, '기타')                               AS TYPE_TEXT -->
        <!-- , CONST.CONSTID                                             AS CONST_NO -->
        <!-- <if test="IS_MONITORING == true">
        , TICKET_TC.LIST                                            AS TC_LIST
        </if> -->
        <!-- <if test="IS_HISTORY == true">
        , CASE
                WHEN T.ticket_type = 'CIT2'
                THEN
                        (
                            SELECT  OCA1.ocaname
                            FROM    inspector.tb_inspector_result_dtl TIR
                                    LEFT OUTER JOIN TOPAS.TB_OCA1 OCA1 ON TIR.OCASEQ = OCA1.OCASEQ
                            WHERE   TIR.inspector_seq = T.ticket_id
                            LIMIT   1
                        )
                ELSE NULL
        END AS CIT2_OCANAME
        , TOPAS_T.LIST AS TOPAS_LIST
        </if> -->
        <!-- , COALESCE(CNT.INFLUENCECIRCUIT_COUNT, 0) AS INFLUENCECIRCUIT_COUNT -->
        <!-- , POST.TRANSCIRCUITSEQ AS POST_TC -->
        <!-- , AI_RESULT.AI_RESULT2
        , AI_RESULT.AI_RESULT_COMMANT -->
    FROM    sub_ticket T
        <!-- LEFT OUTER JOIN  sub_ai AI_RESULT ON (AI_RESULT.ticket_id = T.ticket_id) -->
        LEFT OUTER JOIN (
            SELECT  SUB_AL3.*
                    , ROW_NUMBER() OVER (PARTITION BY SUB_AL3.TICKET_ID ORDER BY SUB_AL3.EQUIP_TYPE_ORDER_NUM<!-- , SUB_AL3.TRANSCIRCUITSEQ DESC -->, TICKET_AL_ID DESC) AS ORDER_NUM
            FROM    (
                    SELECT  
                        SUB_AL2.*
                        , CASE
                            WHEN ROOT_CAUSE_SYSNAMEA LIKE '%ROADM%'
                                OR      ROOT_CAUSE_SYSNAMEZ LIKE '%ROADM%'
                            THEN 1
                            WHEN ROOT_CAUSE_SYSNAMEA LIKE '%POTN%'
                                OR      ROOT_CAUSE_SYSNAMEZ LIKE '%POTN%'
                            THEN 2
                            WHEN ROOT_CAUSE_SYSNAMEA LIKE '%MSPP%'
                                OR      ROOT_CAUSE_SYSNAMEZ LIKE '%MSPP%'
                            THEN 3
                            WHEN ROOT_CAUSE_SYSNAMEA LIKE '%PTS%'
                                OR      ROOT_CAUSE_SYSNAMEZ LIKE '%PTS%'
                            THEN 4
                            ELSE 5
                        END AS EQUIP_TYPE_ORDER_NUM
                    FROM    sub_al SUB_AL2
                    <if test="TICKET_ID != null">
                            WHERE SUB_AL2.TICKET_ID = #{TICKET_ID}::VARCHAR
                    </if>
                    <if test="TICKET_ID_LIKE != null">
                            WHERE SUB_AL2.TICKET_ID LIKE '%' || #{TICKET_ID_LIKE}::VARCHAR || '%'
                    </if>
            ) SUB_AL3
        ) AL ON T.TICKET_ID = AL.TICKET_ID AND     AL.ORDER_NUM = 1
        LEFT OUTER JOIN (
            SELECT  SUB_AL4.ticket_id
                    , 0::int AS ROOT_CAUSE_CHECKA<!-- , COUNT(SUB_AL4.ROOT_CAUSE_CHECKA) FILTER (WHERE SUB_AL4.ROOT_CAUSE_CHECKA = TRUE) AS ROOT_CAUSE_CHECKA -->
                    , 0::int AS ROOT_CAUSE_CHECKZ<!-- , COUNT(SUB_AL4.ROOT_CAUSE_CHECKZ) FILTER (WHERE SUB_AL4.ROOT_CAUSE_CHECKZ = TRUE) AS ROOT_CAUSE_CHECKZ -->
                    , MIN(SUB_AL4.TICKET_AL_ID) AS MBA_AL_ID
            FROM    sub_al SUB_AL4
            GROUP BY SUB_AL4.ticket_id
        ) AL2 ON T.TICKET_ID = AL2.TICKET_ID
        LEFT OUTER JOIN sub_al MBA_AL ON T.TICKET_ID = AL2.TICKET_ID AND T.ROOT_CAUSE_TYPE = 'MomentaryBreakoff' AND MBA_AL.TICKET_AL_ID = AL2.MBA_AL_ID
        <!-- LEFT OUTER JOIN (
                SELECT  SUB_OCA.*
                FROM    (
                    SELECT DISTINCT ON (A.TICKET_ID)
                        (A.OCASEQ)          AS OCASEQ
                        , (A.TRANSCIRCUITSEQ) AS TRANSCIRCUITSEQ
                        , A.TICKET_ID
                        , CL.MAX_RATIO AS MAX_RATIO`
                        , R2.ORDER_NUM AS ORDER_NUM
                    FROM    rca.tb_rca_ticket_ocaseq_current A
                        INNER JOIN rca.tb_ocaroute R2 ON A.OCASEQ = R2.OCASEQ AND     A.TRANSCIRCUITSEQ = R2.TRANSCIRCUITSEQ
                        LEFT OUTER JOIN
                            (
                                    SELECT  B.OCASEQ , B.MAX_RATIO
                                    FROM    rca.tb_oca_cl_count B
                                    GROUP BY B.OCASEQ ,B.MAX_RATIO
                            ) CL ON A.OCASEQ = CL.OCASEQ
                    <if test="IS_MONITORING == true">
                        WHERE A.INSERT_TIME <![CDATA[ >= ]]> RCA.FC_GET_MINUS_DAY(#{TICKET_DAYS} + 3)
                    </if>
                    ORDER BY A.TICKET_ID , CL.MAX_RATIO DESC , R2.ORDER_NUM ASC , A.OCASEQ , A.TRANSCIRCUITSEQ
                ) SUB_OCA
                ORDER BY SUB_OCA.OCASEQ
        ) OCA ON T.TICKET_ID = OCA.TICKET_ID -->
        <!-- LEFT OUTER JOIN ( 
            SELECT  
                *
                , row_number() OVER (PARTITION BY OCASEQ ORDER BY TRANSCIRCUITSEQ DESC) AS TC_ORDER_NUM
            FROM rca.tb_ocaroute
        ) R ON OCA.OCASEQ = R.OCASEQ AND     R.TC_ORDER_NUM = 1 -->
        <!-- LEFT OUTER JOIN topas.tb_oca1 OCA1 ON R.OCASEQ = OCA1.OCASEQ -->
        <!-- LEFT OUTER JOIN aib_inst.tb_instlocation LOC_A ON R.INSTLOCATIONA = LOC_A.INSTLOCATION -->
        <!-- LEFT OUTER JOIN aib_inst.tb_instlocation LOC_Z ON R.INSTLOCATIONZ = LOC_Z.INSTLOCATION -->
        <!-- LEFT OUTER JOIN topas.tb_office OFF_A ON AL.ROOT_CAUSE_OFFICEA = OFF_A.OFFICESCODE -->
        <!-- LEFT OUTER JOIN topas.tb_office OFF_Z ON AL.ROOT_CAUSE_OFFICEZ = OFF_Z.OFFICESCODE -->
        <!-- LEFT OUTER JOIN post.tb_transcircuit_post POST ON POST.TRANSCIRCUITSEQ = AL.TRANSCIRCUITSEQ -->
        LEFT OUTER JOIN (
                SELECT  *
                FROM    rca.tb_rca_ticket_handling_status_current
                WHERE   insert_time <![CDATA[ >= ]]> <include refid="SUB_TICKET_MIN_DAY"/>
                AND     insert_time <![CDATA[ <= ]]> <include refid="SUB_TICKET_MAX_DAY"/>
        ) STATUS ON STATUS.TICKET_ID = T.TICKET_ID
        <!-- LEFT OUTER JOIN rca.tb_code CODE ON CODE.P_CODE = 'TICKET_TYPE' AND     CODE.CODE = T.ROOT_CAUSE_TYPE -->
        <!-- LEFT OUTER JOIN RCA.TB_RCA_TICKET_CONST_CURRENT CONST ON T.TICKET_ID = CONST.TICKET_ID AND ( CONST.TICKET_TYPE = 'RT' OR      CONST.TICKET_TYPE = 'CIT' ) -->
        LEFT OUTER JOIN (
                SELECT  *
                FROM    rca.tb_rca_ticket_cnt
                WHERE   insert_time <![CDATA[ >= ]]> <include refid="SUB_TICKET_MIN_DAY"/>
                AND     insert_time <![CDATA[ <= ]]> <include refid="SUB_TICKET_MAX_DAY"/>
        ) CNT ON T.ticket_id = CNT.ticket_id
    <!-- 모니터링 TC_LIST -->
    <!-- <if test="IS_MONITORING == true"> 
        LEFT OUTER JOIN (
                SELECT  CABLECUT_T.TICKET_ID
                        , ARRAY_TO_JSON(ARRAY_AGG(CABLECUT_T.*))::TEXT AS LIST
                FROM    (
                        SELECT  CABLECUT_T1.*
                                , DENSE_RANK () OVER (PARTITION BY CABLECUT_T1.TICKET_ID ORDER BY CABLECUT_T1.CNT DESC ) RANK_NUMBER
                        FROM    (
                                SELECT DISTINCT CABLECUT_TICKET.TICKET_ID           AS TICKET_ID
                                        , OCA1.OCANAME                                  AS OCANAME
                                        , CL.OCASEQ                                     AS OCASEQ
                                        , LOC_A.LOCDESCRIPTION                          AS LOCDESCRIPTIONA
                                        , LOC_Z.LOCDESCRIPTION                          AS LOCDESCRIPTIONZ
                                        , CL.CNT                                        AS CNT
                                        , CL.CNT1                                       AS CNT1
                                        , T2.RCA_MAX_CNT                                AS RCA_MAX_CNT
                                        , T2.MAX_CNT                                    AS MAX_CNT
                                        , (CL.CNT::FLOAT(2)/T2.RCA_MAX_CNT::FLOAT(2)) AS ORDER_NUM
                                FROM    sub_ticket CABLECUT_TICKET
                                        LEFT OUTER JOIN
                                                (
                                                        SELECT DISTINCT A.OCASEQ AS OCASEQ
                                                                , A.CNT            AS CNT
                                                                , A.CNT1           AS CNT1
                                                                , A.CLUSTER_NO
                                                        FROM    rca.tb_oca_cl_count A
                                                        WHERE   A.insert_time <![CDATA[ >= ]]> <include refid="SUB_TICKET_MIN_DAY"/>
                                                        AND     A.insert_time <![CDATA[ <= ]]> <include refid="SUB_TICKET_MAX_DAY"/>
                                                ) CL                                  ON CL.CLUSTER_NO = CABLECUT_TICKET.CLUSTER_NO
                                        LEFT OUTER JOIN topas.tb_oca1 OCA1          ON CL.OCASEQ = OCA1.OCASEQ
                                        LEFT OUTER JOIN aib_inst.tb_instlocation LOC_A ON OCA1.INSTLOCATIONA = LOC_A.INSTLOCATION
                                        LEFT OUTER JOIN aib_inst.tb_instlocation LOC_Z ON OCA1.INSTLOCATIONZ = LOC_Z.INSTLOCATION
                                        LEFT OUTER JOIN rca.tb_oca_max_count2 T2    ON T2.OCASEQ = CL.OCASEQ
