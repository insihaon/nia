			</if>

		</trim>
	</sql>
	
	<insert id="insertTbAssignTypeCdVo" parameterType="com.kt.ipms.legacy.opermgmt.srvmgmt.vo.TbAssignTypeCdVo">
		INSERT
		INTO MST.TB_ASSIGN_TYPE_CD (
			SASSIGN_TYPE_CD
			,	SASSIGN_TYPE_NM
			,	SCOMMENT
			,	SCREATE_ID
			,	SMODIFY_ID
		
		) VALUES (
			(SELECT 'SA1' || TRIM(TO_CHAR(TO_NUMBER(NVL(MAX(RIGHT(sassign_type_cd,3)),'0')) + 1,'000')) AS sassign_type_cd
				FROM mst.tb_assign_type_cd
				WHERE LEFT(sassign_type_cd,3) = 'SA1')
			,	#{sassignTypeNm, jdbcType=VARCHAR}
			,	#{scomment, jdbcType=VARCHAR}
			,	#{screateId, jdbcType=VARCHAR}
			,	#{smodifyId, jdbcType=VARCHAR}
		
		)
	</insert>
	
	<update id="updateTbAssignTypeCdVo" parameterType="com.kt.ipms.legacy.opermgmt.srvmgmt.vo.TbAssignTypeCdVo">
		UPDATE
		MST.TB_ASSIGN_TYPE_CD A
		SET
			A.DMODIFY_DT = current_timestamp
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(sassignTypeNm)">
				, A.SASSIGN_TYPE_NM = #{sassignTypeNm, jdbcType=VARCHAR}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(sneossDdYn)">
				, A.SNEOSS_DD_YN = #{sneossDdYn, jdbcType=CHAR}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(scomment)">
				, A.SCOMMENT = #{scomment, jdbcType=VARCHAR}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(dcreateDt)">
				, A.DCREATE_DT = #{dcreateDt, jdbcType=TIMESTAMP}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(screateId)">
				, A.SCREATE_ID = #{screateId, jdbcType=VARCHAR}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(smodifyId)">
				, A.SMODIFY_ID = #{smodifyId, jdbcType=VARCHAR}
			</if>

		<include refid="Vo_Where_Clause" />
	</update>
	
