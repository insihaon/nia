		FROM MST.TB_ASSIGN_TYPE_CD A
		<include refid="Vo_Where_Clause" />
	</delete>
	
	<select id="selectTbAssignTypeCdVo" resultMap="tbAssignTypeCdVoResult" parameterType="com.kt.ipms.legacy.opermgmt.srvmgmt.vo.TbAssignTypeCdVo">
