<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
	"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.kt.ipms.legacy.opermgmt.tacsmgmt.dao.TbTacsConnBasDao">
	<resultMap id="tbTacsConnBasVoResult" type="com.kt.ipms.legacy.opermgmt.tacsmgmt.vo.TbTacsConnBasVo">
		<result column="NTACS_CONN_BAS_SEQ" property="ntacsConnBasSeq" jdbcType="BIGINT" />
		<result column="CONN_ID" property="connId" jdbcType="VARCHAR" />
		<result column="CONN_PW" property="connPw" jdbcType="VARCHAR" />
		<result column="CONN_OGW_IP" property="connOgwIp" jdbcType="VARCHAR" />
		<result column="CONN_OGW_PORT" property="connOgwPort" jdbcType="NUMERIC" />
		<result column="CONN_MAC_ADDR" property="connMacAddr" jdbcType="VARCHAR" />
		<result column="DCREATE_DT" property="dcreateDt" jdbcType="TIMESTAMP" />
		<result column="SCREATE_ID" property="screateId" jdbcType="VARCHAR" />
		<result column="DMODIFY_DT" property="dmodifyDt" jdbcType="TIMESTAMP" />
		<result column="SMODIFY_ID" property="smodifyId" jdbcType="VARCHAR" />
		<result column="SMAILADDRESS" property="smailAddress" jdbcType="VARCHAR" />
	</resultMap>

	<sql id="Base_Column_List">
		A.NTACS_CONN_BAS_SEQ, A.CONN_ID, A.CONN_PW, A.CONN_OGW_IP, A.CONN_OGW_PORT, A.CONN_MAC_ADDR
		, A.DCREATE_DT, A.SCREATE_ID, A.DMODIFY_DT, A.SMODIFY_ID, NVL(A.SMAILADDRESS, '') AS SMAILADDRESS

	</sql>
	
	<sql id="Vo_Where_Clause">
		<trim prefix="WHERE" prefixOverrides="AND">
			A.NTACS_CONN_BAS_SEQ = #{ntacsConnBasSeq, jdbcType=BIGINT}
		</trim>
	</sql>
	
	<select id="selectTbTacsConnBasVo" resultMap="tbTacsConnBasVoResult">
		SELECT
		<include refid="Base_Column_List" />
		FROM MST.TB_TACS_CONN_BAS A
	</select>
	
	<update id="updateTbTacsConnBasVo" parameterType="com.kt.ipms.legacy.opermgmt.tacsmgmt.vo.TbTacsConnBasVo">
		UPDATE
		MST.TB_TACS_CONN_BAS A
		SET
			A.CONN_ID = #{connId, jdbcType=VARCHAR}
			, A.CONN_PW = #{connPw, jdbcType=VARCHAR}
			, A.CONN_OGW_IP = #{connOgwIp, javaType=Object, jdbcType=OTHER, typeHandler=com.kt.ipms.legacy.cmn.typehandler.CIDRTypeHandler}
			, A.CONN_OGW_PORT = #{connOgwPort, jdbcType=NUMERIC}
			, A.CONN_MAC_ADDR = #{connMacAddr, jdbcType=VARCHAR}
			, DMODIFY_DT = sysdate
			, A.SMAILADDRESS = #{smailAddress, jdbcType=VARCHAR}
		<include refid="Vo_Where_Clause" />
	</update>
	
</mapper>
