<mapper namespace="com.kt.ipms.legacy.opermgmt.orgmgmt.dao.TbLvlSubCdDao">
	<resultMap id="tbLvlSubCdVoResult" type="com.kt.ipms.legacy.opermgmt.orgmgmt.vo.TbLvlSubCdVo">
