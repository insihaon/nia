		FROM MST.TB_LVL_SUB_CD A
		<include refid="Vo_Where_Clause" />
	</delete>
	
	<select id="selectTbLvlSubCdVo" resultMap="tbLvlSubCdVoResult" parameterType="com.kt.ipms.legacy.opermgmt.orgmgmt.vo.TbLvlSubCdVo">
		SELECT
		<include refid="Base_Column_List" />
		<include refid="Append_Column_List"/>
		FROM MST.TB_LVL_SUB_CD A
		<include refid="Append_From_Clause"/>
		<include refid="Vo_Where_Clause" />
		<include refid="Append_Where_Clause"/>
	</select>
	
	<select id="selectListTbLvlSubCdVo" resultMap="tbLvlSubCdVoResult" parameterType="com.kt.ipms.legacy.opermgmt.orgmgmt.vo.TbLvlSubCdVo">
		SELECT
		<include refid="Base_Column_List" />
		<include refid="Append_Column_List"/>
		FROM MST.TB_LVL_SUB_CD A, MST.TB_LVL_CD B
		WHERE 1=1 
		AND A.SSVC_LINE_TYPE_CD = #{ssvcLineTypeCd}
		AND A.SLVL_CD = #{slvlCd}
		AND A.SLOFFICECODE = B.SLVL_CD(+)
		ORDER BY B.SLVL_NM
	</select>
	
	
	<select id="countListTbLvlSubCdVo" resultType="int" parameterType="com.kt.ipms.legacy.opermgmt.orgmgmt.vo.TbLvlSubCdVo">
		SELECT
			count(1) totalCount
		FROM MST.TB_LVL_SUB_CD A
		<include refid="Append_From_Clause"/>
		<include refid="List_Where_Clause" />
		<include refid="Append_Where_Clause"/>
	</select>
	
	<select id="selectListPageTbLvlSubCdVo" resultMap="tbLvlSubCdVoResult" parameterType="com.kt.ipms.legacy.opermgmt.orgmgmt.vo.TbLvlSubCdVo">
		SELECT <include refid="Base_Column_List" />
			   <include refid="Append_Column_List_Alias"/>, A.RNUM FROM (
			SELECT <include refid="Base_Column_List" />
				   <include refid="Append_Column_List_Alias"/>, ROWNUM RNUM FROM (
				SELECT
				<include refid="Base_Column_List" />
				<include refid="Append_Column_List"/>
				FROM MST.TB_LVL_SUB_CD A
				<include refid="Append_From_Clause"/>
				<include refid="List_Where_Clause" />
				<include refid="Append_Where_Clause"/>
			) A WHERE ROWNUM <![CDATA[<=]]> #{lastIndex}
		) A WHERE RNUM <![CDATA[>=]]> #{firstIndex}
	</select>
	
	<select id="countListPageTbLvlSubCdVo" resultType="int" parameterType="com.kt.ipms.legacy.opermgmt.orgmgmt.vo.TbLvlSubCdVo">
		SELECT
			count(1) totalCount
		FROM MST.TB_LVL_SUB_CD A
		<include refid="Append_From_Clause"/>
		<include refid="List_Where_Clause" />
		<include refid="Append_Where_Clause"/>
	</select>
	
	
	<select id="selectSloffice" resultType="int" parameterType="com.kt.ipms.legacy.opermgmt.orgmgmt.vo.TbLvlSubCdVo">
		SELECT
			count(1) totalCount
		FROM MST.TB_LVL_SUB_CD A
		WHERE 1=1 
		AND A.SSVC_LINE_TYPE_CD = #{ssvcLineTypeCd}
		AND A.SLOFFICECODE = #{slofficecode}

