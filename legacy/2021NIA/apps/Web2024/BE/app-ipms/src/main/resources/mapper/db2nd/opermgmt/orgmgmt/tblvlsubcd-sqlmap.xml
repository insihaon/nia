	<sql id="Base_Column_List">
		A.SSVC_LINE_TYPE_CD, A.SLVL_CD, A.SLOFFICECODE, A.SCOMMENT
		, A.DCREATE_DT, A.SCREATE_ID, A.DMODIFY_DT, A.SMODIFY_ID

	</sql>
	
	<sql id="Append_Column_List">
	,B.SLVL_NM AS SLOFFICNM
	</sql>
	
	<sql id="Append_Column_List_Alias">
	
	</sql>
	
	<sql id="Append_From_Clause">
	
	</sql>
	
	<sql id="Append_Where_Clause">
	
	</sql>
	
	<sql id="Vo_Where_Clause">
		<trim prefix="WHERE" prefixOverrides="AND">
<!-- 			A.SSVC_LINE_TYPE_CD = #{ssvcLineTypeCd, jdbcType=CHAR}
				AND A.SLVL_CD = #{slvlCd, jdbcType=CHAR}
				AND A.SLOFFICECODE = #{slofficecode, jdbcType=CHAR} -->
				
				<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(ssvcLineTypeCd)">
				A.SSVC_LINE_TYPE_CD = #{ssvcLineTypeCd, jdbcType=CHAR}
				</if>
				<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(slvlCd)">
				AND A.SLVL_CD = #{slvlCd, jdbcType=CHAR}
				</if>
				<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(slofficecode)">
				AND A.SLOFFICECODE = #{slofficecode, jdbcType=CHAR}
				</if>

		</trim>
	</sql>

	<sql id="List_Where_Clause">
		<trim prefix="WHERE" prefixOverrides="AND">
			1 = 1
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(ssvcLineTypeCd)">
				AND A.SSVC_LINE_TYPE_CD = #{ssvcLineTypeCd, jdbcType=CHAR}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(slvlCd)">
				AND A.SLVL_CD = #{slvlCd, jdbcType=CHAR}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(slofficecode)">
				AND A.SLOFFICECODE = #{slofficecode, jdbcType=CHAR}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(scomment)">
				AND A.SCOMMENT = #{scomment, jdbcType=VARCHAR}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(dcreateDt)">
				AND A.DCREATE_DT = #{dcreateDt, jdbcType=TIMESTAMP}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(screateId)">
				AND A.SCREATE_ID = #{screateId, jdbcType=VARCHAR}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(dmodifyDt)">
				AND A.DMODIFY_DT = #{dmodifyDt, jdbcType=TIMESTAMP}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(smodifyId)">
				AND A.SMODIFY_ID = #{smodifyId, jdbcType=VARCHAR}
			</if>

		</trim>
	</sql>
	
	<insert id="insertTbLvlSubCdVo" parameterType="com.kt.ipms.legacy.opermgmt.orgmgmt.vo.TbLvlSubCdVo">
		INSERT
		INTO MST.TB_LVL_SUB_CD (
			SSVC_LINE_TYPE_CD
			,	SLVL_CD
			,	SLOFFICECODE
			,	DCREATE_DT
			,	SCREATE_ID
			, 	DMODIFY_DT
			,	SMODIFY_ID
		
		) VALUES (
			#{ssvcLineTypeCd, jdbcType=CHAR}
			,	#{slvlCd, jdbcType=CHAR}
			,	#{slofficecode, jdbcType=CHAR}
			,	sysdate
			,	#{smodifyId, jdbcType=VARCHAR}
			,	sysdate
			,	#{smodifyId, jdbcType=VARCHAR}
		
		)
	</insert>
	
	<update id="updateTbLvlSubCdVo" parameterType="com.kt.ipms.legacy.opermgmt.orgmgmt.vo.TbLvlSubCdVo">
		UPDATE
		MST.TB_LVL_SUB_CD A
		SET
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(scomment)">
			A.SCOMMENT = #{scomment, jdbcType=VARCHAR}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(dcreateDt)">
				, A.DCREATE_DT = #{dcreateDt, jdbcType=TIMESTAMP}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(screateId)">
				, A.SCREATE_ID = #{screateId, jdbcType=VARCHAR}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(dmodifyDt)">
				, A.DMODIFY_DT = #{dmodifyDt, jdbcType=TIMESTAMP}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(smodifyId)">
				, A.SMODIFY_ID = #{smodifyId, jdbcType=VARCHAR}
			</if>

		<include refid="Vo_Where_Clause" />
	</update>
	
	<delete id="deleteTbLvlSubCdVo" parameterType="com.kt.ipms.legacy.opermgmt.orgmgmt.vo.TbLvlSubCdVo">
