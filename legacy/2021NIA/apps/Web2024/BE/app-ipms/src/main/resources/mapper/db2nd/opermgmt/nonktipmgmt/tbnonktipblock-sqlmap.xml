	<sql id="Base_Column_List">
		A.NNON_KT_IPBLOCK_SEQ, A.NNON_KT_SVC_MST_SEQ
		, A.SIP_BLOCK, A.NBITMASK, A,SFLAG, A.DCREATE_DT, A.SCREATE_ID
		, A.DMODIFY_DT, A.SMODIFY_ID, A.SCOMMENT

	</sql>
	
	<sql id="Append_Column_List">
		, B.SFLAG_TYPE_NM AS SFLAG_TYPE_NM
	</sql>
	
	<sql id="Append_Column_List_Alias">
		, A.SFLAG_TYPE_NM
	</sql>
	
	<sql id="Append_From_Clause">
		, MST.V_TB_NON_KT_SVC_MST_SFLAG_TYPE_CD B
		, (SELECT MAX(NNON_KT_IPBLOCK_SEQ) AS NNON_KT_IPBLOCK_SEQ FROM BIF.TB_NON_KT_IPBLOCK GROUP BY NNON_KT_SVC_MST_SEQ,SIP_BLOCK ) C
	</sql>
	
	<sql id="Append_Where_Clause">
		AND A.SFLAG = B.SFLAG_TYPE_CD(+)
		AND A.NNON_KT_IPBLOCK_SEQ = C.NNON_KT_IPBLOCK_SEQ
		AND A.SFLAG !='D'
	</sql>
	
	<sql id="Vo_Where_Clause">
		<trim prefix="WHERE" prefixOverrides="AND">
			A.NNON_KT_IPBLOCK_SEQ = #{nnonKtIpblockSeq, jdbcType=BIGINT}
			
		</trim>
	</sql>
	
	<sql id="Check_Vo_Where_Clause">
		<trim prefix="WHERE" prefixOverrides="AND">
			A.NNON_KT_SVC_MST_SEQ = #{nnonKtSvcMstSeq, jdbcType=BIGINT}
			AND A.SIP_BLOCK =  #{sipBlock, jdbcType=VARCHAR}
		</trim>
	</sql>
	

	<sql id="List_Where_Clause">
		<trim prefix="WHERE" prefixOverrides="AND">
			1 = 1
			AND A.SFLAG != 'D' 
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(nnonKtIpblockSeq)">
				AND A.NNON_KT_IPBLOCK_SEQ = #{nnonKtIpblockSeq, jdbcType=BIGINT}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(nnonKtSvcMstSeq)">
				AND A.NNON_KT_SVC_MST_SEQ = #{nnonKtSvcMstSeq, jdbcType=BIGINT}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(sipBlock)">
				AND A.SIP_BLOCK = #{sipBlock, jdbcType=VARCHAR}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(nbitmask)">
				AND A.NBITMASK = #{nbitmask, jdbcType=INTEGER}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(nbitmask)">
				AND A.SFLAG = #{sflag, jdbcType=VARCHAR}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(dcreateDt)">
				AND A.DCREATE_DT = #{dcreateDt, jdbcType=TIMESTAMP}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(screateId)">
