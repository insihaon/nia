		<result column="NNON_KT_SVC_MST_SEQ" property="nnonKtSvcMstSeq" jdbcType="BIGINT" />
		<result column="SIP_CREATE_TYPE_CD" property="sipCreateTypeCd" jdbcType="CHAR" />
