	<update id="updateTbNonKtIpblockVo" parameterType="com.kt.ipms.legacy.opermgmt.nonktipmgmt.vo.TbNonKtIpblockVo">
		UPDATE
		BIF.TB_NON_KT_IPBLOCK A
		SET
			A.DMODIFY_DT = current_timestamp
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(sipBlock)">
				, A.SIP_BLOCK = #{sipBlock, jdbcType=VARCHAR}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(nbitmask)">
				, A.NBITMASK = #{nbitmask, jdbcType=INTEGER}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(dcreateDt)">
				, A.DCREATE_DT = #{dcreateDt, jdbcType=TIMESTAMP}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(screateId)">
