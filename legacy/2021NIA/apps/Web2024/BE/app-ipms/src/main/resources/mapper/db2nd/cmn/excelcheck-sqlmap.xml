<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
	"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.kt.ipms.legacy.cmn.dao.ExcelCheckDao">

	<select id="selectExcelDown" resultType="String">
		SELECT down_flag
		FROM mst.tb_excel_check
	</select>
	
	<select id="selectExcelUp" resultType="String">
		SELECT up_flag
		FROM mst.tb_excel_check
	</select>
	
	<select id="selectModifyDt" resultType="String">
		SELECT dmodify_dt
		FROM mst.tb_excel_check
	</select>
	
	<update id="updateExcelDown" parameterType="String">
		UPDATE mst.tb_excel_check
		SET down_flag =#{excel_flag}, dmodify_dt = now()
		where 1=1
	</update>
	
	<update id="updateExcelup" parameterType="String">
		UPDATE mst.tb_excel_check
		SET up_flag =#{excel_flag}, dmodify_dt = now()
		where 1=1
	</update>
</mapper>