	<select id="selectListPageTbScrnBasVo" resultMap="tbScrnBasVoResult" parameterType="com.kt.ipms.legacy.opermgmt.menumgmt.vo.TbScrnBasVo">
		SELECT <include refid="Base_Column_List" />
			   <include refid="Append_Column_List_Alias"/>, A.RNUM FROM (
			SELECT <include refid="Base_Column_List" />
			   <include refid="Append_Column_List_Alias"/>, ROWNUM RNUM FROM (
				SELECT
					
				<include refid="Base_Column_List" />
				<include refid="Append_Column_List"/>
				FROM MST.TB_SCRN_BAS A
				<include refid="Append_From_Clause"/>
				<include refid="List_Where_Clause" />
				<include refid="Append_Where_Clause"/>
				ORDER BY SSCRN_ID
			) A WHERE ROWNUM <![CDATA[<=]]> #{lastIndex}
		)A WHERE RNUM <![CDATA[>=]]> #{firstIndex}
	</select>
	
	<select id="countListPageTbScrnBasVo" resultType="int" parameterType="com.kt.ipms.legacy.opermgmt.menumgmt.vo.TbScrnBasVo">
