			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(smodifyId)">
				AND A.SMODIFY_ID = #{smodifyId, jdbcType=VARCHAR}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(searchCnd)">
				<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(searchWrd)">
					<if test= 'searchCnd == "sscrnId"'>
						AND A.SSCRN_ID = #{searchWrd, jdbcType=VARCHAR}
					</if>
					<if test= 'searchCnd == "sscrnNm"'>
						AND A.SSCRN_NM	ILIKE '%' || #{searchWrd, jdbcType=VARCHAR} || '%'
					</if>	
					<if test= 'searchCnd == "sdgnScrnId"'>
						AND A.SDGN_SCRN_ID = #{searchWrd, jdbcType=VARCHAR}
					</if>
				</if>
			</if>

		</trim>
	</sql>
	
	<sql id="Append_Where_Clause">
		AND A.SSCRN_TYPE_CD = B.SSCRN_TYPE_CD(+)
		AND A.SSCRN_URL_TYPE_CD = C.SSCRN_URL_TYPE_CD(+)
	</sql>
	
