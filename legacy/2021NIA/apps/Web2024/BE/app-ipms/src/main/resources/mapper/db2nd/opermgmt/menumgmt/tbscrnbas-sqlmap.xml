			UPDATE
				
				MST.TB_SCRN_BAS
				SET
			SSCRN_USE_YN = #{sscrnUseYn, jdbcType=CHAR}
			WHERE
			<if test="tbScrnBasVos != null">
			SSCRN_ID IN
				<foreach collection="tbScrnBasVos" item="item" separator="," open="(" close=")">
					 #{item.sscrnId, jdbcType=CHAR}
				</foreach>
			</if>
			AND SSCRN_USE_YN != #{sscrnUseYn, jdbcType=CHAR}
	</update>
	
	<select id="selectNewsscrnId" resultType="String" >
		SELECT
			
	   		'S'||TRIM(TO_CHAR(TO_NUMBER(DECODE(MAX(RIGHT(SSCRN_ID,5)),NULL,'00000',MAX(RIGHT(SSCRN_ID,5))))+1, '00000')) AS NEW_SSCRN_ID
