		</trim>
	</sql>

	<sql id="List_Where_Clause">
		<trim prefix="WHERE" prefixOverrides="AND">
			1 = 1
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(sscrnId)">
				AND A.SSCRN_ID = #{sscrnId, jdbcType=VARCHAR}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(sscrnNm)">
				AND A.SSCRN_NM = #{sscrnNm, jdbcType=VARCHAR}
