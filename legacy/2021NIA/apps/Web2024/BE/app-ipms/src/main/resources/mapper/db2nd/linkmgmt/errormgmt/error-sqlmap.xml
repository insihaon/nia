<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
	"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
	
<mapper namespace="com.kt.ipms.legacy.linkmgmt.errormgmt.dao.ErrorMgmtDao">
	<resultMap id="ErrorMgmtVoResult" type="com.kt.ipms.legacy.linkmgmt.errormgmt.vo.ErrorMgmtVo">
		<result column="seq" property="seq" jdbcType="BIGINT" />
		<result column="ipbitmask" property="ipbitmask" jdbcType="NUMERIC" />
		<result column="nip_assign_mst_seq" property="nipAssignMstSeq" jdbcType="VARCHAR" />
		<result column="slacpblockyn" property="slacpBlockYN" jdbcType="VARCHAR" />
		<result column="ip_block" property="ipBlock" jdbcType="VARCHAR" />
		<result column="svc_use_type_cd" property="svcUseTypeCd" jdbcType="VARCHAR" />
		<result column="svc_use_type_nm" property="svcUseTypeNm" jdbcType="VARCHAR" />
		<result column="ipms_svc_seq" property="ipmsSvcSeq" jdbcType="VARCHAR" />
		<result column="assign_type_cd" property="assignTypeCd" jdbcType="VARCHAR" />
		<result column="assign_type_nm" property="assignTypeNm" jdbcType="VARCHAR" />
		<result column="ex_svc_cd" property="exSvcCd" jdbcType="VARCHAR" />
		<result column="ex_svc_nm" property="exSvcNm" jdbcType="VARCHAR" />
		<result column="ip_version_type_cd" property="ipVersionTypeCd" jdbcType="VARCHAR" />
		<result column="ip_version_type_nm" property="ipVersionTypeNm" jdbcType="VARCHAR" />
		<result column="ip_create_type_cd" property="ipCreateTypeCd" jdbcType="VARCHAR" />
		<result column="ip_create_type_nm" property="ipCreateTypeNm" jdbcType="VARCHAR" />
		<result column="sipaddr" property="sipaddr" jdbcType="VARCHAR" />
		<result column="eipaddr" property="eipaddr" jdbcType="VARCHAR" />
		<result column="gatewayip" property="eipaddr" jdbcType="VARCHAR" />
		<result column="ssaid" property="ssaid" jdbcType="VARCHAR" />
		<result column="sllnum" property="sllnum" jdbcType="VARCHAR" />
		<result column="error_result_cd" property="errorResultCd" jdbcType="VARCHAR" />
		<result column="error_result_nm" property="errorResultNm" jdbcType="VARCHAR" />
		<result column="dcreate_dt" property="dCreateDt" jdbcType="TIMESTAMP" />
		<result column="dcomplete_dt" property="dCompleteDt" jdbcType="TIMESTAMP" />
		<result column="screate_id" property="sCreateId" jdbcType="VARCHAR" />
		<result column="smodify_id" property="sModifyId" jdbcType="VARCHAR" />
	</resultMap>

	<sql id="List_Where_Clause">
		<trim prefix="WHERE" prefixOverrides="AND">
			1 = 1
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(seq)">
				AND A.seq = #{seq, jdbcType=BIGINT}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(errorResultCd)">
				AND A.error_result_cd = #{errorResultCd, jdbcType=VARCHAR}
			</if>
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(searchCnd)">
				<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(searchWrd)">
					<if test= 'searchCnd == "ipBlock"'>
						AND A.ip_block LIKE '%' || #{searchWrd, jdbcType=VARCHAR} || '%'
					</if>
					<if test= 'searchCnd == "sllnum"'>
						AND A.sllnum LIKE '%' || #{searchWrd, jdbcType=VARCHAR} || '%'
					</if>
				</if>
			</if>
		</trim>
	</sql>
	
	<select id="selectListErrorMgmtVo" resultMap="ErrorMgmtVoResult" parameterType="com.kt.ipms.legacy.linkmgmt.errormgmt.vo.ErrorMgmtVo">
		select 
			A.seq as seq,
			A.ipbitmask as ipbitmask,
			A.nip_assign_mst_seq as nip_assign_mst_seq,
			A.slacpblockyn as slacpblockyn,
			A.ip_block as ip_block,
			A.svc_use_type_cd as svc_use_type_cd,
			A.ipms_svc_seq as ipms_svc_seq,
			A.assign_type_cd as assign_type_cd,
			A.ex_svc_cd as ex_svc_cd,
			A.ip_version_type_cd as ip_version_type_cd,
			A.ip_create_type_cd as ip_create_type_cd,
			A.sipaddr as sipaddr,
			A.eipaddr as eipaddr,
			A.gatewayip as gatewayip,
			A.ssaid as ssaid,
			A.sllnum as sllnum,
			A.error_result_cd as error_result_cd,
			(select error_result_nm from mst.tb_neoss_error_manage_cd where error_result_cd = A.error_result_cd) as error_result_nm,
			A.dcreate_dt as dcreate_dt,
			A.RNUM
		FROM(
			select 
				A.seq, A.ipbitmask, A.nip_assign_mst_seq, A.slacpblockyn, A.ip_block, A.svc_use_type_cd, A.ipms_svc_seq, A.assign_type_cd, A.ex_svc_cd, A.ip_version_type_cd,
				A.ip_create_type_cd, A.sipaddr, A.eipaddr, A.gatewayip, A.ssaid, A.sllnum, A.error_result_cd, A.dcreate_dt, ROWNUM RNUM
			from
				(
					select
						seq
						, ipbitmask
						, nip_assign_mst_seq
						, slacpblockyn 
						, ip_block
						, svc_use_type_cd
						, ipms_svc_seq
						, assign_type_cd
						, ex_svc_cd
						, ip_version_type_cd
						, ip_create_type_cd
						, sipaddr
						, eipaddr
						, gatewayip
						, ssaid
						, sllnum
						, error_result_cd
						, dcreate_dt
					from 
						mst.tb_neoss_error_manage A
					<include refid="List_Where_Clause" />
					<choose>
						<when test="sortType == 'dcreate_dt'">
							ORDER BY A.dcreate_dt 
							<choose>
									<when test="sortOrdr == 'ASC'">
										ASC
									</when>
									<when test="sortOrdr == 'DESC'">
										DESC
									</when>
									<otherwise>
										ASC
									</otherwise>
							</choose>
						</when>
						<when test="sortType == 'seq'">
							ORDER BY A.seq 
							<choose>
								<when test="sortOrdr == 'ASC'">
									ASC
								</when>
								<when test="sortOrdr == 'DESC'">
									DESC
								</when>
								<otherwise>
									ASC
								</otherwise>
							</choose>
						</when>
					</choose>
				) A WHERE ROWNUM <![CDATA[<=]]> #{lastIndex}
		)A WHERE RNUM <![CDATA[>=]]> #{firstIndex}
	</select>
	
	<select id="countListPageErrorMgmtVo" resultType="int" parameterType="com.kt.ipms.legacy.linkmgmt.errormgmt.vo.ErrorMgmtVo">
		SELECT 
			count(1)
		FROM mst.tb_neoss_error_manage A
		<include refid="List_Where_Clause" />
	</select>
	
	<update id="updateTbNeossErrorManage" parameterType="com.kt.ipms.legacy.linkmgmt.errormgmt.vo.ErrorMgmtListVo">
		UPDATE
			mst.tb_neoss_error_manage A
		SET
			A.error_result_cd = 'NE0002'
			,A.dmodify_dt = sysdate
			<if test="@org.apache.commons.lang.StringUtils@isNotEmpty(sModifyId)">
				,A.smodify_id = #{sModifyId, jdbcType=TIMESTAMP}
			</if>
		WHERE
			1 = 1
			<if test="errorMgmtVos != null">
				AND A.seq IN 
				<foreach collection="errorMgmtVos" item="item" separator="," open="(" close=")">
					#{item.seq, jdbcType=BIGINT}
				</foreach>
			</if>
	</update>
</mapper>