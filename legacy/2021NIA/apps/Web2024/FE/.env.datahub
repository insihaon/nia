# just a flag
NODE_ENV = production
# BASE_URL = /datahub/portal

# base api
VUE_APP_PROJECT = datahub
VUE_APP_TITLE = HUB
VUE_APP_BASE_API = '["//localhost:8070", "/mock"]'
VUE_APP_BASE_API_INDEX = 0
VUE_APP_WS_RETRY_MAX = 30 
