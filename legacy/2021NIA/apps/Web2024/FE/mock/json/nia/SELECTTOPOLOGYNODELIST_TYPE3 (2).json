{
    "data": {
        "success": true,
        "encrypt": false,
        "sql": [
            "SELECT\n            row_number() over () AS index\n            , node.id\n            , node.device_name\n            , node.ip_addr\n            , node.device_type\n            , node.visible\n            , coalesce(cast (node.fx as integer), 20 + (node.index * 80)) as fx\n            , coalesce(cast (node.fx as integer), 20 + (node.index * 80)) as x\n            , coalesce(cast (node.fy as integer), 100) as fy\n            , coalesce(cast (node.fy as integer), 100) as y\n        from (\n            SELECT DISTINCT ON (nm.node_id, nm.node_nm, nm.ip_addr)\n                row_number() over () AS index\n                , nm.node_num\n                , nm.node_id AS id\n                , nm.node_nm AS device_name\n                , nm.ip_addr AS ip_addr\n                , '4' as device_type\n                , case when nm.admin_yn = 'W' then true\n                    else false end as visible\n                , np.fx as fx  \n                , np.fy  as fy\n            FROM resource.tb_node_mst nm\n            LEFT OUTER JOIN resource.tb_node_position_info np ON np.node_id = nm.node_id AND np.topology_type = '3'\n            where np.fx is not null\n            UNION \n            SELECT distinct on (em.tid, em.sysname, em.model)\n                row_number() over () AS index\n                , null as node_num\n                , em.tid AS id\n                , em.sysname  AS device_name\n                , em.tid AS ip_addr\n                , CASE model\n                WHEN 'Utrans-6300p-H3' THEN '1'\n                WHEN 'Utrans-6300p-V9' THEN '0'\n                ELSE '2'\n                END AS device_type\n                , true as visible\n                , np.fx as fx\n                , np.fy  as fy\n            FROM nia.tb_equip_mst em\n            LEFT OUTER JOIN resource.tb_node_position_info np ON np.node_id = em.tid AND np.topology_type= '3'\n            order by node_num\n        ) as node"
        ],
        "total": 45,
