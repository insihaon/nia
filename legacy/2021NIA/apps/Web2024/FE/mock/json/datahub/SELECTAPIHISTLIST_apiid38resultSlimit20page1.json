        "encrypt": false,
        "sql": "SELECT \n    TAIPH.API_ID\n   \t,TAIPH.PROC_SERIAL \n   \t, TAIPH.RESULT_CD\n    , TAIPH.RESULT_MSG\n    , TAIPH.RETRY_PROC\n    , TAIPH.REQUEST_PARAM\n   \t, TAM.API_NAME\n   \t, TAM.API_URL\n   \t, TAM.API_DESC\n   \t, TO_CHAR(TAIPH.CREATE_TIME, 'YYYY-MM-DD HH24:MI:SS') AS CREATE_TIME\n    , TO_CHAR(TAM.UPDATE_TIME, 'YYYY-MM-DD HH24:MI:SS') as UPDATE_TIME\n    , TISM.SYSTEM_NM\n    , TAARH.API_URL as TARGETURL\n    ,CASE\n        WHEN EXEC_MODE_CD = 'B' THEN 'Batch'\n        WHEN EXEC_MODE_CD = 'F' THEN 'SFTP'\n        ELSE 'OnDemand'\n    END AS EXEC_MODE_CD\n    ,CASE\n        WHEN RESULT_CD = 'S' THEN 'SUCCESS'\n        ELSE 'FAIL'\n    END AS RESULT_CD_DESC\n    FROM DATAHUB.TB_API_INTRL_PROC_HIST TAIPH\n    LEFT JOIN DATAHUB.TB_API_MST TAM ON TAM.API_ID = TAIPH.API_ID\n    LEFT JOIN DATAHUB.TB_INTRL_SYSTEM_MST TISM ON TAM.SYSTEM_ID  = TISM.SYSTEM_ID\n    LEFT JOIN (\n        SELECT API_ID, API_URL\n        FROM DATAHUB.TB_API_AUTH_REQ_HIST TAARH\n        WHERE SYSTEM_ID IS NOT null and status_cd = 'GRANT'\n        GROUP BY API_ID, API_URL\n    ) TAARH ON TAARH.API_ID = TAIPH.API_ID\n    WHERE 1=1\n            AND TAIPH.API_ID = 38\n            AND TAIPH.RESULT_CD = 'S'\n            LIMIT 20 OFFSET 0",
