rule "POTN_ETH_UNI_B_SF"
salience 700
lock-on-active
no-loop
    when
        //conditions
        flagTF : Flag(flag == false)
        $a1 : BasicAlarmVo(topology != null, topology.nwType == RcaCodeInfo.TOPOLOGY_GB_UNI, alarmmsg == RcaCodeInfo.ALARM_POTN_ETH_LOS)
        $a2 : BasicAlarmVo(sysname == $a1.sysname, topology != null, topology.oppSysname == $a1.topology.oppSysname, slot != $a1.slot, alarmmsg == RcaCodeInfo.ALARM_POTN_ETH_LOS)
        $a3 : BasicAlarmVo(sysname == $a1.topology.oppSysname, slot == $a1.topology.oppSlot, alarmmsg == RcaCodeInfo.ALARM_POTN_ETH_LOS)
    then
        //actions
        rcaResult.setRcaResultCode("POTN_ETH_UNI_B_SF");
        rcaResult.setFaultDetailCode("이더넷 UNI 주/예비 수신단 양방향 링크장애");
        rcaResult.setRcaResultTypeCode(RcaCodeInfo.RCA_RESULT_LINKCUT);
        rcaResult.addRelatedAlarm($a1);
        rcaResult.addRelatedAlarm($a2);

        flagTF.setFlag(true);
        update(flagTF);
end


