salience 600
lock-on-active
no-loop
    when
        //conditions
        flagTF : Flag(flag == false)
        $a1 : BasicAlarmVo(topology != null, topology.nwType == RcaCodeInfo.TOPOLOGY_GB_NNI, alarmmsg == RcaCodeInfo.ALARM_POTN_WDM_LOS)
        $a2 : BasicAlarmVo(sysname == $a1.topology.oppSysname, slot == $a1.topology.oppSlot, alarmmsg == RcaCodeInfo.ALARM_POTN_WDM_LOS)
    then
        //actions
        rcaResult.setRcaResultCode("POTN_WDM_NNI_SF_BI");
        rcaResult.setFaultDetailCode("WDM NNI 수신단 양방향 링크장애");
        rcaResult.setRcaResultTypeCode(RcaCodeInfo.RCA_RESULT_LINKCUT);
        rcaResult.addRelatedAlarm($a1);
        rcaResult.addRelatedAlarm($a2);

        flagTF.setFlag(true);
        update(flagTF);
end


