//declare any global variables here
global RcaResult rcaResult;


rule "POTN_NODE_ISOLATION"
salience 1000
lock-on-active
no-loop
    when
        //conditions
        flagTF : Flag(flag == false)
        $a1 : BasicAlarmVo(alarmmsg == RcaCodeInfo.ALARM_POTN_NODE_ISOLATION)
    then
        //actions
        rcaResult.setRcaResultCode("POTN_NODE_ISOLATION");
        rcaResult.setFaultDetailCode("노드 고립");
        rcaResult.setRcaResultTypeCode(RcaCodeInfo.RCA_RESULT_ETC_FAIL);
        rcaResult.addRelatedAlarm($a1);

        flagTF.setFlag(true);
        update(flagTF);
end


