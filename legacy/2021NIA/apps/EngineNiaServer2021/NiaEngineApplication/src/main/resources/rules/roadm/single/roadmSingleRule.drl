rule "ROADM_WDM_SF_BI_CASE2"
salience 700
lock-on-active
no-loop
    when
        //conditions
        flagTF : Flag(flag == false)
        $a1 : BasicAlarmVo(alarmmsg == RcaCodeInfo.ALARM_ROADM_WDM_LOS, (unit matches "LAUp" || matches "MRSA-2A" || matches "PAUp"))
        $a2 : BasicAlarmVo(sysname == $a1.topology.oppSysname, ptpname == $a1.topology.oppPtpName, alarmmsg == RcaCodeInfo.ALARM_ROADM_WDM_LOS)
    then
        //actions
        rcaResult.setRcaResultCode("ROADM_WDM_SF_BI");
        rcaResult.setFaultDetailCode("WDM NNI 수신단 양방향 링크 장애");
        rcaResult.setDomainCode(RcaCodeInfo.DOMAIN_ROADM);
        rcaResult.setRcaResultTypeCode(RcaCodeInfo.RCA_RESULT_LINKCUT);
        rcaResult.addRelatedAlarm($a1);
        rcaResult.addRelatedAlarm($a2);

        flagTF.setFlag(true);
        update(flagTF);
end


rule "ROADM_WDM_SF_BI_CASE3"
salience 700
lock-on-active
no-loop
    when
        //conditions
        flagTF : Flag(flag == false)
        $a1 : BasicAlarmVo(alarmmsg == RcaCodeInfo.ALARM_ROADM_WDM_LOS, (unit matches "LAUp" || matches "MRSA-2A" || matches "PAUp"))
        $a2 : BasicAlarmVo(sysname == $a1.topology.oppSysname, $a1.topology.oppPtpName != "", alarmmsg == RcaCodeInfo.ALARM_ROADM_WDM_LOS,
        Integer.parseInt(ptpname.substring(ptpname.length()-1)) == Integer.parseInt($a1.topology.oppPtpName.substring($a1.topology.oppPtpName.length()-1)) + 1)
    then
        //actions
        rcaResult.setRcaResultCode("ROADM_WDM_SF_BI");
        rcaResult.setFaultDetailCode("WDM NNI 수신단 양방향 링크 장애");
        rcaResult.setDomainCode(RcaCodeInfo.DOMAIN_ROADM);
        rcaResult.setRcaResultTypeCode(RcaCodeInfo.RCA_RESULT_LINKCUT);
        rcaResult.addRelatedAlarm($a1);
        rcaResult.addRelatedAlarm($a2);

        flagTF.setFlag(true);
        update(flagTF);
end


