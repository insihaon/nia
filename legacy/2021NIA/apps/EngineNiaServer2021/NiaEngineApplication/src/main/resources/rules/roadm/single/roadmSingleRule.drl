//declare any global variables here
global RcaResult rcaResult;


rule "ROADM_NVRAM_ERR"
salience 1000
lock-on-active
no-loop
    when
        //conditions
        flagTF : Flag(flag == false)
        $a1 : BasicAlarmVo(alarmmsg == RcaCodeInfo.ALARM_ROADM_NVRAM_FAIL)
    then
        //actions
        rcaResult.setRcaResultCode("ROADM_NVRAM_ERR");
        rcaResult.setFaultDetailCode("NVRAM 고장");
        rcaResult.setDomainCode(RcaCodeInfo.DOMAIN_ROADM);
        rcaResult.setRcaResultTypeCode(RcaCodeInfo.RCA_RESULT_ETC_FAIL);
        rcaResult.addRelatedAlarm($a1);

        flagTF.setFlag(true);
        update(flagTF);
end


rule "ROADM_FAN_OUT"
salience 900
lock-on-active
no-loop
    when
        //conditions
        flagTF : Flag(flag == false)
        $a1 : BasicAlarmVo(alarmmsg matches RcaCodeInfo.ALARM_ROADM_COW_FAN_M1_FAIL || matches RcaCodeInfo.ALARM_ROADM_COW_FAN_M2_FAIL ||
        matches RcaCodeInfo.ALARM_ROADM_COW_FAN_M3_FAIL || matches RcaCodeInfo.ALARM_ROADM_COW_FAN_M4_FAIL)
    then
        //actions
        rcaResult.setRcaResultCode("ROADM_FAN_OUT");
        rcaResult.setFaultDetailCode("FAN 모듈 탈장");
        rcaResult.setDomainCode(RcaCodeInfo.DOMAIN_ROADM);
        rcaResult.setRcaResultTypeCode(RcaCodeInfo.RCA_RESULT_UNIT_FAIL);
        rcaResult.addRelatedAlarm($a1);

        flagTF.setFlag(true);
        update(flagTF);
end


rule "ROADM_UNIT_OUT_CASE1"
salience 900
lock-on-active
no-loop
    when
        //conditions
        flagTF : Flag(flag == false)
        $a1 : BasicAlarmVo(alarmmsg == RcaCodeInfo.ALARM_ROADM_CARD_OUT,
        (unit matches "BAUp" || matches "LAUp" || matches "MRSA-2A" || matches "PAUp" || matches "WSUp-2"))
    then
        //actions
        rcaResult.setRcaResultCode("ROADM_UNIT_OUT_" + $a1.getUnit());
        rcaResult.setFaultDetailCode("공통부 " + $a1.getUnit() + " 유닛 탈장");
        rcaResult.setDomainCode(RcaCodeInfo.DOMAIN_ROADM);
        rcaResult.setRcaResultTypeCode(RcaCodeInfo.RCA_RESULT_UNIT_FAIL);
        rcaResult.addRelatedAlarm($a1);

        flagTF.setFlag(true);
        update(flagTF);
end


