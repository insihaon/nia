rule "ROADM_PWR_FAIL_RACK_CASE1"
salience 800
lock-on-active
no-loop
    when
        //conditions
        flagTF : Flag(flag == false)
        $a1 : BasicAlarmVo(unit == "CCU", alarmmsg == RcaCodeInfo.ALARM_ROADM_PDU_PWR_A_FAIL)
        $a2 : BasicAlarmVo(sysname == $a1.sysname, unit == "CCU", alarmmsg == RcaCodeInfo.ALARM_ROADM_FAN_PWR_A_FAIL)
        $a3 : BasicAlarmVo(sysname == $a1.sysname, unit == "CCU", alarmmsg == RcaCodeInfo.ALARM_ROADM_RACK_PWR_A_FAIL)
        $a4 : BasicAlarmVo(sysname == $a1.sysname, unit == "WCU", alarmmsg == RcaCodeInfo.ALARM_ROADM_PDU_PWR_A_FAIL)
        $a5 : BasicAlarmVo(sysname == $a1.sysname, unit == "WCU", alarmmsg == RcaCodeInfo.ALARM_ROADM_FAN_PWR_A_FAIL)
        $a6 : BasicAlarmVo(sysname == $a1.sysname, unit == "WCU", alarmmsg == RcaCodeInfo.ALARM_ROADM_RACK_PWR_A_FAIL)
    then
        //actions
        rcaResult.setRcaResultCode("ROADM_PWR_FAIL_RACK");
        rcaResult.setFaultDetailCode("전원부 랙 장애");
        rcaResult.setDomainCode(RcaCodeInfo.DOMAIN_ROADM);
        rcaResult.setRcaResultTypeCode(RcaCodeInfo.RCA_RESULT_POWER_FAIL);
        rcaResult.addRelatedAlarm($a1);

        flagTF.setFlag(true);
        update(flagTF);
end


