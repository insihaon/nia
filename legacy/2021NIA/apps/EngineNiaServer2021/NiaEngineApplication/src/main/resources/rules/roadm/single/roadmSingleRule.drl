rule "ROADM_UNI_SF_BI_CASE1"
salience 400
lock-on-active
no-loop
    when
        //conditions
        flagTF : Flag(flag == false)
        $a1 : BasicAlarmVo(topology != null, alarmmsg == RcaCodeInfo.ALARM_ROADM_UNI_LOCAL_LOS,
        (unit matches "OT2A-2" || matches "OT2A-4" || matches "OT2HU_2" ||
        matches "OT2U_2" || matches "OTUC2A" || matches "OTUXA" ||
        matches "OM24A" || matches "OM24U" || matches "OTNU_C" ||
        matches "OM2C2A-L" || matches "OTUC1A-L"))
        $a2 : BasicAlarmVo(sysname == $a1.topology.oppSysname, slot == $a1.topology.oppSlot, alarmmsg == RcaCodeInfo.ALARM_ROADM_UNI_REMOTE_SF)
    then
        //actions
        rcaResult.setRcaResultCode("ROADM_UNI_SF_BI");
        rcaResult.setFaultDetailCode("UNI 수신단 양방향 링크 장애");
        rcaResult.setDomainCode(RcaCodeInfo.DOMAIN_ROADM);
        rcaResult.setRcaResultTypeCode(RcaCodeInfo.RCA_RESULT_LINKCUT);
        rcaResult.addRelatedAlarm($a1);
        rcaResult.addRelatedAlarm($a2);

        flagTF.setFlag(true);
        update(flagTF);
end


