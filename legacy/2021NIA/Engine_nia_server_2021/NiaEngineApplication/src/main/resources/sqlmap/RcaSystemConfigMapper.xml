<mapper namespace="com.nia.engine.mapper.RcaSystemConfigMapper">

	<select id="selectSystemConfig" resultType="string" parameterType="hashmap">
		SELECT FACTOR_VALUE FROM RCA.AL_SYSTEM_CONFIG WHERE FACTOR = #{factor}
