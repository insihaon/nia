#!/usr/bin/env bash
set -euo pipefail

# init-api-key.sh (버전 10 플러그인 설치 포함)
# - analysis-nori 플러그인 설치
# - 사전 발급된 API Key 지원
# - ES 기동 → 대기 → 키 생성/로딩 → 출력 → 프로세스 유지

# 0) 환경 및 비밀번호 로드
ES_USER="elastic"
if [[ -n "${ELASTIC_PASSWORD_FILE:-}" && -f "${ELASTIC_PASSWORD_FILE}" ]]; then
  ES_PASSWORD=$(<"${ELASTIC_PASSWORD_FILE}")
elif [[ -n "${ELASTIC_PASSWORD:-}" ]]; then
  ES_PASSWORD="$ELASTIC_PASSWORD"
else
  echo "[ERROR] ELASTIC_PASSWORD_FILE 또는 ELASTIC_PASSWORD 필요" >&2
  exit 1
fi

# 1) 프로토콜 및 curl 옵션 설정
if [[ "${ES_XPACK_SECURITY_ENABLED:-true}" == "false" ]]; then
  ES_HOST="http://localhost:9200"
  CURL_OPTS=""
else
  ES_HOST="https://localhost:9200"
  CURL_OPTS="-k -u ${ES_USER}:${ES_PASSWORD}"
fi

# 2) 경로 및 변수 정의
data_dir="/usr/share/elasticsearch/data"
api_key_file="${data_dir}/api_key.json"
api_name="docker-auto-key"

# 3) analysis-nori 플러그인 설치 (없을 때만)
plugin_dir="/usr/share/elasticsearch/plugins/analysis-nori"
if [[ ! -d "${plugin_dir}" ]]; then
  echo "[INFO] Installing analysis-nori plugin..."
  /usr/share/elasticsearch/bin/elasticsearch-plugin install --batch analysis-nori
fi

# 4) Elasticsearch 백그라운드 기동 및 가용성 대기
echo "[INFO] Starting Elasticsearch..."
/usr/local/bin/docker-entrypoint.sh eswrapper &
ES_PID=$!
echo "[INFO] Waiting for Elasticsearch at ${ES_HOST}..."
until curl ${CURL_OPTS} -s -o /dev/null -w "%{http_code}" "${ES_HOST}" | grep -qE '^[23]..$'; do
  echo "[DEBUG] ES not ready, retrying..."
  sleep 2
done
echo "[INFO] Elasticsearch is up!"

# 5) 데이터 디렉토리 준비
mkdir -p "${data_dir}"

# 6) API Key 생성 또는 재사용
echo "[INFO] Handling API Key..."
if [[ -n "${INIT_API_KEY_ENCODED:-}" ]]; then
  echo "[INFO] Using preset API Key"
  cat > "${api_key_file}" <<EOF
{
  "id": "${INIT_API_KEY_ID:-preserved}",
  "name": "${api_name}",
  "api_key": "(preserved)",
  "encoded": "${INIT_API_KEY_ENCODED}"
}
EOF
elif [[ ! -f "${api_key_file}" ]]; then
  echo "[INFO] Generating new API Key"
  curl ${CURL_OPTS} -s -X POST "${ES_HOST}/_security/api_key?pretty" \
    -H 'Content-Type: application/json' \
    -d '{"name":"'"${api_name}"'","role_descriptors":{"full_manager":{"cluster":["manage","manage_api_key","read_security"],"index":[{"names":["*"],"privileges":["all"]}]}}}' \
    > "${api_key_file}"
fi

# 7) API Key(encoded) 출력
echo "================================================================================"
ENC_KEY=$(jq -r .encoded < "${api_key_file}" 2>/dev/null || sed -n 's/.*"encoded"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "${api_key_file}")
echo "[INFO] Elasticsearch API Key (encoded): ${ENC_KEY}"
echo "[INFO] To test: curl ${CURL_OPTS} -H 'Authorization: ApiKey ${ENC_KEY}' '${ES_HOST}/_security/api_key?owner=true&pretty'"
echo "================================================================================"

# 8) ES 프로세스 대기
wait ${ES_PID}
