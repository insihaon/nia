#!/usr/bin/env python3
# -*- coding: utf-8 -*-

import os
import sys
import requests
from elasticsearch import Elasticsearch, helpers

# ─── 환경변수 및 상수 정의 ───────────────────────────────────────────────────
ES_URL     = os.getenv("ES_URL",     "https://localhost:9200")
ES_USER    = os.getenv("ES_USER",    "elastic")
ES_PASS    = os.getenv("ES_PASS",    "changeme123")
ES_VERIFY  = os.getenv("ES_VERIFY",  "false").lower() == "true"
ES_TIMEOUT = int(os.getenv("ES_TIMEOUT", "30"))

# ─── 1) Basic Auth 연결 테스트 ─────────────────────────────────────────────────
def test_connection():
    try:
        resp = requests.get(
            ES_URL + "/",
            auth=(ES_USER, ES_PASS),
            verify=ES_VERIFY,
            timeout=ES_TIMEOUT
        )
        resp.raise_for_status()
    except requests.RequestException as e:
        print(f"[ERROR] ES 연결 테스트 실패: {e}")
        sys.exit(1)
    print("[INFO] ES 연결 테스트 성공 (GET /)")

# ─── 2) Elasticsearch 클라이언트 생성 (Basic Auth) ─────────────────────────────
def get_es_client() -> Elasticsearch:
    client = Elasticsearch(
        hosts=[ES_URL],
        basic_auth=(ES_USER, ES_PASS),
        verify_certs=ES_VERIFY,
        max_retries=3,
        retry_on_timeout=True,
        request_timeout=ES_TIMEOUT
    )
    try:
        info = client.info()
        print(f"[INFO] ES 연결 성공: cluster={info['cluster_name']}, node={info['name']}")
    except Exception as e:
        print(f"[ERROR] ES info() 실패: {e}")
        sys.exit(1)
    return client

# ─── 3) 주요 기능: 인덱스 생성, 색인, 검색, 전체 인덱스 조회, 전체 문서 조회 ─────────────
def create_index(es: Elasticsearch, idx: str):
    if not es.indices.exists(index=idx):
        body = {
            "settings": {"analysis": {"analyzer": {"default": {"type": "standard"}}}},
            "mappings": {
                "properties": {
                    "question": {"type": "text"},
                    "answer":   {"type": "text", "index": False},
                    "created":  {"type": "date"}
                }
            }
        }
        es.indices.create(index=idx, body=body, request_timeout=ES_TIMEOUT)
        print(f"[INFO] 인덱스 생성됨: {idx}")
    else:
        print(f"[INFO] 인덱스 이미 존재함: {idx}")

def index_doc(es: Elasticsearch, idx: str, doc_id: int, doc: dict):
    res = es.index(index=idx, id=doc_id, document=doc, request_timeout=ES_TIMEOUT)
    print(f"[INFO] 문서 색인 완료: ID={res['_id']}")

def bulk_index(es: Elasticsearch, idx: str, docs: list[dict]):
    actions = [{"_index": idx, "_id": d["id"], "_source": d} for d in docs]
    helpers.bulk(es, actions, request_timeout=ES_TIMEOUT)
    print(f"[INFO] Bulk 색인 완료: 총 {len(docs)}건")

def search_docs(es: Elasticsearch, idx: str, query: str, size: int = 10):
    """
    match 쿼리로 검색을 수행하고,
    • _score(유사도) 순으로 정렬
    • 각 hit의 ID, score, question, created 출력
    """
    body = {
        "query": {
            "match": {
                "question": {
                    "query": query
                }
            }
        },
        "size": size
    }
    # explicit sort by _score (descending)
    res = es.search(
        index=idx,
        body=body,
        sort=["_score"],
        request_timeout=ES_TIMEOUT
    )
    hits = res.get("hits", {}).get("hits", [])
    print(f"[INFO] '{query}' 검색 결과: {len(hits)}건 (유사도 순)")
    for hit in hits:
        src   = hit["_source"]
        score = hit.get("_score", 0)
        print(f"  - ID={hit['_id']}, score={score:.3f}, question={src['question']}, created={src['created']}")

    # 0번째 hit의 answer 출력
    if hits:
        first_answer = hits[0]["_source"]["answer"]
        print(f" >>> {first_answer}")

    # 더 다양한 옵션: track_total_hits, highlight 등  
    # API 문서: Elasticsearch.search()  
    # https://elasticsearch-py.readthedocs.io/en/latest/api.html#elasticsearch.Elasticsearch.search  
    # 전체 URL: https://elasticsearch-py.readthedocs.io/en/latest/api.html#elasticsearch.Elasticsearch.search


def list_indices(es: Elasticsearch):
    indices = es.cat.indices(format="json", request_timeout=ES_TIMEOUT)
    print(f"[INFO] 전체 인덱스 목록 ({len(indices)}개):")
    for idx in indices:
        print(f"  - {idx['index']} (status={idx['status']}, docs={idx['docs.count']})")

def print_all_docs(es: Elasticsearch, idx: str, batch_size: int = 1000):
    """
    helpers.scan 으로 모든 문서를 Scroll API 기반으로 조회하여 출력
    • size=batch_size: 한 번에 가져올 문서 수
    • scan(): _scroll_id 관리 및 페이징을 자동으로 처리
    """
    print(f"[INFO] 인덱스 '{idx}' 전체 문서 출력 시작")
    for hit in helpers.scan(
        client=es,
        index=idx,
        query={"query": {"match_all": {}}},
        size=batch_size,
        request_timeout=ES_TIMEOUT
    ):
        src = hit["_source"]
        print(f"  - ID={hit['_id']}, source={src}")
    print(f"[INFO] 인덱스 '{idx}' 전체 문서 출력 완료")

# ─── 메인 실행 ────────────────────────────────────────────────────────────────
if __name__ == "__main__":
    test_connection()
    ES = get_es_client()
    INDEX = "my-index"

    # 기본 예제
    create_index(ES, INDEX)
    index_doc(ES, INDEX, 1, {
        "question": "Docker로 Elasticsearch 설치 방법?",
        "answer":   "docker-compose.yml 작성 후 docker-compose up 실행",
        "created":  "2025-07-11T17:05:00"
    })
    sample = [
        {"id":2, "question":"Nori란?",        "answer":"한글 형태소 분석기", "created":"2025-07-11T17:06:00"},
        {"id":3, "question":"match 쿼리 예제", "answer":"Elasticsearch match…", "created":"2025-07-11T17:07:00"}
    ]
    bulk_index(ES, INDEX, sample)

    # 검색 예제
    search_docs(ES, INDEX, "Nori란 무엇인가?")

    # 전체 인덱스 조회 예제
    list_indices(ES)

    # 특정 인덱스의 전체 문서 출력 예제
    print_all_docs(ES, INDEX)
